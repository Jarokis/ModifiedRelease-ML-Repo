  {
    "section": "Materials Origin",
    "content": {
      "source": "Materials section",
      "details": "Tara gum (TG) isolate and other excipients (talc, Aerosil, magnesium stearate, lactose DCL21, sodium starch glycolate) were obtained from Vineet Analytical Research Laboratories Pvt Ltd. (Pioma Chemicals, Mumbai, Maharashtra, India)."
    }
  },
  {
    "section": "Experimental Design for Optimization",
    "content": {
      "source": "Materials and methods section",
      "details": "Tablets containing imatinib were developed using TG extract. Conventional tablets were made with a variable ratio of excipients to TG utilizing the direct compression process. All excipients were well-mixed except magnesium stearate. Following adequate mixing of the extract and other ingredients, Aerosil and magnesium stearate were added and combined for a further 2-3 min."
    }
  },
  {
    "section": "Ingredients Identification",
    "content": {
      "source": "Materials and methods, Phytochemical screening, Content uniformity sections",
      "details": {
        "preparation": "The optimized tablet formulation was used for the initial phytochemical per standard procedures [18]. For content uniformity, 10 tablets from each formulation were ground into a fine powder. Part of the powder (20 mg of imatinib) was dissolved in methanol, filtered, and appropriately diluted.",
        "results": "Phytochemical screening revealed the presence of saponins, tannins, phenolics, flavonoids, carbohydrates, proteins, and amino acids. Steroids, alkaloids, fats, and oils were absent.",
        "equation": "% F = {1 - (Wt / W)} × 100 (for friability)",
        "absorbance": "Absorbance for drug content and dissolution studies was measured at 238 nm using a UV-visible spectrophotometer."
      }
    }
  },
