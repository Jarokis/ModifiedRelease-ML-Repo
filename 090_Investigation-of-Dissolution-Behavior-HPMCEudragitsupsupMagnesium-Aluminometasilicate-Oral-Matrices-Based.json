{
    "article_title": "Investigation of Dissolution Behavior HPMC/Eudragit/Magnesium Aluminometasilicate Oral Matrices Based on NMR Solid-State Spectroscopy and Dynamic Characteristics of Gel Layer",
    "materials_origin": {
        "Levetiracetam": "Zentiva k.s., Prague, Czech Republic",
        "Neusilin_US2": "Fuji Chemical Industries Co., Ltd., Toyoma, Japan",
        "HPMC_K4M": "Methocel® K4M, Dow Chemicals, Midland, USA",
