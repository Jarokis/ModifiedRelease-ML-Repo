        "Magnesium_stearate": "Peter Greven, Bad Münstereifel, Germany",
        "Colloidal_silicon_dioxide": "Degussa, Vicenza, Italy"
    },
    "experimental_design": "The study investigated the effect of Eudragit NE concentration (5%, 7.5%, 10% solid) and Neusilin US2 amount (50 mg, 100 mg) on dissolution behavior of levetiracetam from HPMC matrices. Thermal treatment (70°C for 24h) was applied to granules or tablets. Multivariate analysis (PCA, ANOVA) was used to assess significance.",
    "ingredients_identification": {
        "preparation": "Granules were prepared by high-shear wet granulation using Eudragit NE30D dispersion as granulation liquid applied to API/Neusilin mixture. HPMC and other excipients were added extragranularly. Tablets were compressed.",
        "analytical_method": "HPLC with Venusil XBP C18 column (150×4.6 mm, 3 μm), mobile phase: 68% phosphoric acid (0.2%) and 32% methanol, detection at 220 nm, flow rate 1.0 mL/min, column temperature 27°C, injection volume 20 μL.",
        "results": "Drug content was determined and stability confirmed after 12 months.",
        "equation": "Not applicable",
        "absorbance": "220 nm"
    },
