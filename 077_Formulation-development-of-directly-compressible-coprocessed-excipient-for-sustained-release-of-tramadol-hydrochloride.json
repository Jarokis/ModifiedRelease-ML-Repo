{
    "article_summary": {
        "title": "Formulation development of directly compressible co-processed excipient for sustained release of tramadol hydrochloride",
        "objective": "To prepare and evaluate directly compressible co-processed excipient for sustained release tablets using tramadol hydrochloride as a model drug.",
        "conclusion": "Co-processed glyceryl monostearate and dicalcium phosphate dihydrate improved flowability, compressibility, and provided sustained release. Batch 077_F14 was optimized and stable for 3 months."
    },
    "materials_origin": {
        "glyceryl_monostearate": "Yarrow Chem. Products",
        "dicalcium_phosphate_dihydrate": "Yarrow Chem. Products",
        "povidone_PVP_K30": "Balaji Drugs",
        "magnesium_stearate": "SD Fine Chem. Ltd.",
        "talc": "Chemport Private Ltd.",
        "tramadol_hydrochloride": "Cadila Healthcare Limited, Ahmedabad (India) - gift sample"
    },
    "experimental_design": {
        "type": "Box-Behnken design (3³)",
        "independent_variables": [
            {
                "name": "X1",
                "description": "Percentage of glyceryl monostearate",
                "low": 30,
                "medium": 45,
                "high": 60
            },
            {
                "name": "X2",
                "description": "Ratio of dicalcium phosphate dihydrate : glyceryl monostearate",
                "low": "60:40",
                "medium": "50:50",
                "high": "40:60"
            },
            {
                "name": "X3",
                "description": "Concentration of binder (PVP K30)",
                "low": 5,
                "medium": 7,
                "high": 9
            }
        ],
        "dependent_variables": [
            {
                "name": "Y1",
                "description": "Drug release at 3 h (Q3)",
                "specification": "20 ≤ Y1 ≥ 45"
            },
            {
                "name": "Y2",
                "description": "Drug release at 6 h (Q6)",
                "specification": "45 ≤ Y2 ≥ 75"
            },
            {
                "name": "Y3",
                "description": "Drug release at 12 h (Q12)",
                "specification": "75 ≤ Y3 ≥ 100"
            },
            {
                "name": "Y4",
                "description": "Carr's index",
                "specification": "10 ≤ Y4"
            }
        ],
        "quadratic_model_equation": "Y = b0 + b1X1 + b2X2 + b3X3 + b12X1X2 + b13X1X3 + b23X2X3 + b11X1² + b22X2² + b33X3²"
    },
