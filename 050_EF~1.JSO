    "experimental_data": {
        "key_findings": {
            "tablet_hardness": "MCC > SDRS > DCP. Tablets with Dowex 50W (spherical) were harder than those with Amberlite 050_IRP69 (rod/plate-like).",
            "disintegration_time": "MCC and DCP < 30 sec; SDRS resulted in longer times due to gel formation.",
            "drug_release": "Release followed particle diffusion model (-ln(1-F) vs t^0.65). DCP with Dowex 50W showed increased release rate (resinate fracture). Amberlite 050_IRP69 (higher cross-linking) resisted fracture, protecting release profile."
        },
        "statistical_analysis": "One-way ANOVA with least significant difference test (P < 0.05) was used to determine significant effects."
    }
}