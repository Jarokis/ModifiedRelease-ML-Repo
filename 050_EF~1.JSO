        "sodium_starch_glycolate_explotab": "Rama Production Co, Thailand",
        "magnesium_stearate": "Mallinckrodt Inc, St Louis, MO",
        "methanol_benzene_hcl": "Analytical grade, used as received"
    },
    "experimental_design_for_optimization": {
        "purpose": "To investigate the effect of different polysulfonate resins (Dowex 50W and Amberlite 050_IRP69) and direct compression fillers (MCC, DCP, SDRS) on physical properties and drug release of sustained-release DMP resinate tablets.",
        "independent_variables": [
            {
                "variable": "Type of polysulfonate resin",
                "levels": [
                    "Dowex 50W",
                    "Amberlite 050_IRP69"
                ]
            },
            {
                "variable": "Type of direct compression filler",
                "levels": [
                    "MCC",
                    "DCP",
                    "SDRS"
                ]
            },
            {
                "variable": "Compression pressure",
                "levels": [
                    "1 MPa",
                    "2 MPa",
                    "4 MPa"
                ]
            }
        ]
    },
    "ingredients_identification": {
        "dmp_resinate_preparation": {
            "method": "Batch process. Resin (10g) was added to 500 mL of 2% w/v DMP HBr solution and shaken in a water bath at 37°C for 2 hours. The resinates were filtered, washed with distilled water, and dried overnight at 50°C.",
            "drug_loading_results": {
                "dowex_50w": "43.3 ± 0.3% w/w",
                "amberlite_irp69": "32.9 ± 0.3% w/w"
            },
            "absorbance_wavelength": "278 nm (Model UV-1201, Shimadzu, Kyoto, Japan)",
            "equation_for_release_kinetics": "-ln(1 - F) = kt^0.65, where F is fractional drug release, k is release rate constant, and t is time. This is derived from a particle diffusion-controlled model."
        }
    },
