    "process_parameters": {
        "compression_device": "Single punch tableting machine (Shanghai Pharmaceutical Machinery Factory, China)",
        "pressure": "Not specified (hardness used as control, 40-60 N)",
        "coating_process": "Compression coating: half of coating powder filled into die, core tablet centered, remaining coating powder added, then compressed to 8 mm diameter tablets",
        "equipment_used": "USP dissolution apparatus I (basket) and II (paddle); HPLC (LC-10AT, Shimadzu); SEM (SU8010, HITACHI); DSC-204 (Netzsch); FT-IR (IFS 113 v)",
        "process_conditions": {
            "dissolution_temperature": "37±0.5°C",
            "rotation_speed": "100 rpm",
            "dissolution_media": "SGF pH 1.2 (2h) then SIF pH 6.8 (10h)",
            "HPLC_conditions": "Column ODS-3C18 (4.6×250 mm, 5 μm), 35°C; mobile phase methanol/water 80:20 v/v; flow rate 1.0 mL/min; UV detection 243 nm"
