    "experimental_design_for_optimization": {
        "design_type": "Screening of CS/SA weight ratios for PEC film formation and compression coating",
        "independent_variables": [
            "CS/SA weight ratio",
            "core/coating weight ratio",
            "filler type and ratio"
        ],
        "response_variables": [
            "Swelling ratio",
            "Film integrity",
            "Drug release kinetics (zero-order R²)",
            "In vivo Tmax, Cmax, AUC"
        ],
        "optimal_formulation": {
            "core_tablet": "APAP 40 mg, MCC 15 mg, lactose 45 mg",
            "coating_layer": "CS 60 mg, SA 60 mg",
            "total_weight_per_tablet": "220 mg"
        }
    },
