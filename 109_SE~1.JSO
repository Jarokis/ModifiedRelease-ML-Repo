    "release_properties_for_F1_F5": {
        "note": "Release properties for 109_F1-109_F5 matrix tablets are not reported as drug release profiles; instead, swelling ratios and film formation were studied. Drug release studies were performed on compression-coated tablets (not 109_F1-109_F5).",
        "swelling_behavior": {
            "F1_CS_SA_1_0": "Fast initial swelling, then plateau from 4-12h",
            "F2_10_1": "Similar to 109_F1",
            "F3_1_1": "Continuous increase in swelling ratio over 12h (fast first 4h, slower 4-12h)",
            "F4_1_10": "Rapid descent after transfer to SIF (disintegration)",
            "F5_0_1": "Rapid descent after transfer to SIF (complete dissolution)"
        },
        "release_mechanism_for_compression_coated_tablets_optimal": {
            "zero_order_R2": 0.997,
            "first_order_R2": 0.927,
