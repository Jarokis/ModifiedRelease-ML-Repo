    "experimental_data": {
        "swelling_study_equation": "SR = (Wt - W0)/W0 × 100%",
        "zero_order_equation": "Mt/M∞ = kt",
        "first_order_equation": "ln(1 - Mt/M∞) = -kt",
        "korsmeyer_peppas_equation": "Mt/M∞ = k tⁿ",
