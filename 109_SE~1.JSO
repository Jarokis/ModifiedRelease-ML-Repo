{
    "article_summary": {
        "title": "Self-assembled polyelectrolyte complexes films as efficient compression coating layers for controlled-releasing tablets",
        "objective": "Develop zero-order releasing compression-coated tablets using chitosan (CS) and sodium alginate (SA) as outer layer coating material, with paracetamol (APAP) as model drug."
    },
    "sections_identification": {
        "abstract": "Pages 1",
        "introduction": "Pages 1-2",
        "materials_and_methods": "Pages 2-4 (sections 2.1 to 2.8)",
        "results": "Pages 5-10 (section 3)",
        "discussion": "Pages 10-11 (section 4)",
        "conclusion": "Page 11 (section 5)"
    },
    "materials_origin": {
        "paracetamol_APAP": "Aladdin Biological Technology co., LTD. (Shanghai, China)",
        "chitosan_300_kDa": "Aoxing Biotechnology co., LTD. (Zhejiang, China)",
        "sodium_alginate_386_mPa_s": "Huanghai Biopharmaceutical co., LTD. (Qingdao, China)",
        "theophylline_internal_standard": "Yitai Technology co., LTD. (Wuhan, China)",
        "microcrystalline_cellulose_MCC_Avicel_PH101": "Asahi Kasei. Co., Ltd. (Tokyo, Japan)",
