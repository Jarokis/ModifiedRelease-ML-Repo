    "tablet_fabrications_for_each_batch_F1_F5": {
        "method": "Direct compression using single punch tablet machine (Shanghai Pharmaceutical Machinery Factory, China)",
        "punch_diameter": "8 mm (notching punch)",
        "hardness_determination": "Monsanto hardness tester, adjusted to 40-60 N",
        "friability": "Not reported",
        "weight_variation": "Not reported, but total weight target 150 mg",
