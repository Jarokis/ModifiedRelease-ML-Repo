  "process_parameters": {
    "compression_device": "Single punch carver hydraulic hand press (model c, Carver Inc., Menomonee falls, Wisconsin, USA)",
    "die_diameter": "10.5 mm",
    "compression_pressures": "0.5, 0.75, 1.0, 1.25 MN/m²",
    "lubricant": "1% w/v magnesium stearate in acetone",
    "wet_granulation_conditions": "Granulating fluid: 4% or 8% dispersion of polymer; granules dried in oven (Model DHG-9053A, Ocean Medical, England) at 50°C",
    "dissolution_apparatus": "DBK dissolution test apparatus (Type 40DRT01, DBK Instruments Mumbai, India), basket method, 100 rpm, 500 mL 0.1N HCl at 37±2°C",
    "disintegration_apparatus": "DBK disintegration testing apparatus (DBK Instruments Mumbai, India), distilled water at 37.0±0.2°C"
  },
  "release_properties": {
    "general_observations": "All formulations showed 81-99% drug release sustained for 12 hours. Release mechanism determined by Korsmeyer-Peppas model.",
    "release_kinetics_tables": {
      "direct_compression": {
        "NG_4": {"Korsmeyer_R2": 0.976, "n": 0.485, "mechanism": "Anomalous (diffusion+swelling)"},
        "NG_8": {"Korsmeyer_R2": 0.977, "n": 0.425, "mechanism": "Diffusion"},
        "PMG_4": {"Korsmeyer_R2": 0.973, "n": 0.465, "mechanism": "Anomalous"},
