{
  "materials_origin": {
    "enterolobium_gum": "Collected from Botanical garden, University of Ibadan, Nigeria",
    "metronidazole": "Vision pharmaceutical Co Ltd, China",
    "hpmc": "Source not specified",
    "other_reagents": "Analar grade",
    "corn_starch": "Source not specified",
    "lactose": "Source not specified"
  },
  "experimental_design": {
    "type": "2^3 full factorial design",
    "factors": [
      {
        "name": "Nature of polymer",
        "symbol": "X1",
        "levels": {
          "-1": "Low value (specific polymer not explicitly defined in paper, likely native gum)",
          "+1": "High value (likely modified gum, either physically or chemically)"
        }
      },
      {
        "name": "Concentration of polymer",
        "symbol": "X2",
        "levels": {
          "-1": "4% w/w",
          "+1": "8% w/w"
        }
      },
      {
        "name": "Processing technique",
        "symbol": "X3",
        "levels": {
          "-1": "Direct compression",
          "+1": "Wet granulation"
        }
      }
    ],
    "response_variables": ["Tensile strength", "Friability", "Disintegration time"],
    "number_of_batches": 8,
    "statistical_analysis": "Student's t-test, p ≤ 0.05 significant; Minitab© 14.2"
  },
  "ingredients_identification": {
    "native_gum_preparation": "Extracted from incised trunk of Enterolobium cyclocarpum (details in previous studies)",
    "physical_modification": "70% w/v gum solution at 70°C mixed with 20.5 g ethylene glycol, cooled, dried at 60°C, pulverized",
    "chemical_modification": "20 g gum dispersed in 100 mL distilled water, stirred 30 min, pH adjusted to 8.0 with NaOH, added 1.2 g acetic anhydride, reacted 5 min, pH adjusted to 4.5 with 0.5 M HCl, filtered, washed with ethanol, dried, pulverized",
    "viscosity_measurement": "Brookfield viscometer model DV-11+ Pro at 50 and 100 rpm, spindle 04, 2% w/v dispersion",
    "swelling_index_equation": "Swelling capacity = V2 / V1 (V1 = volume before hydration, V2 after 24 h)",
    "density_equations": "Bulk density = Mass / (π r² h); Tapped density after 250 taps at 25 taps/min",
    "carrs_index_equation": "Carr's Index = (Tapped density - Bulk density) / Tapped density × 100",
    "angle_of_repose_equation": "tan θ = h / r",
    "particle_size": "Optical microscope MT 3300EXII, MicrotracBel, Japan, photomicrographs at 20 kV",
    "absorbance_wavelength": "265 nm (UV/Vis spectrophotometer Spectrumlab 752S12078)"
  },
