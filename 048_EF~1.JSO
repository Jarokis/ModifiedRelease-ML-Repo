    "factors_influencing_release": "Binder type and concentration, processing technique, polymer modification (chemical modification significantly affected release, physical modification did not)."
  },
  "tablet_properties": {
    "factorial_batches_responses": "See formulation_details_batches for tensile strength, friability, disintegration time of batches 1-8.",
    "other_properties_reported": "For individual polymer formulations, crushing strength, thickness, weight, disintegration time (sec) given in Tables 3 and 4. No stability data, water uptake, floating time, or lag time reported.",
    "disintegration_time_acceptance": "All uncoated tablets had DT < 15 min (BP limit) except some wet granulation batches? Actually DT for wet granulation NG/4 was 249 sec (~4 min) still <15 min. OK."
  },
  "experimental_data": {
    "key_results": "Enterolobium gum (native and modified) produced tablets with 81-99% drug release sustained for 12 hours. Chemical modification increased drug release similar to HPMC. Physical modification did not significantly alter release. Wet granulation gave higher mechanical strength. Factorial analysis: X1 (polymer nature) had highest effect on disintegration time; X1X3 interaction greatest effect on mechanical properties; X1X2 interaction greatest effect on drug release.",
    "performance_metrics": {
      "tensile_strength_range_KgF": "0.43 - 0.94 (factorial batches)",
      "friability_range_percent": "0.87 - 1.99 (factorial batches)",
      "disintegration_time_range_min": "4.86 - 124 (factorial batches)"
    },
    "statistical_analysis": "Student's t-test, p ≤ 0.05 significant. Main effects: X1 effect on DT = 5.427, X2 effect on DT = 1.607, X3 effect on DT = -2.493. Interaction coefficients: X1X2 on DT = -1.672, X1X3 on DT = 1.428, X2X3 on DT = 0.608.",
    "zero_and_first_order_release": "All formulations had highest R² in Korsmeyer-Peppas model (0.96-0.99); zero-order R² ranged 0.584-0.765; first-order R² 0.793-0.880.",
    "swelling_water_uptake": "Only polymer swelling indices reported (see pre_compression_parameters); no tablet swelling or floating studies.",
