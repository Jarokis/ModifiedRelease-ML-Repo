{
    "article_summary": "Development of 5-aminosalicylic acid (5-ASA) colonic delivery pellets using alginate, calcium, and Eudragit® RS via extrusion-spheronization, with curing and coating to control drug release.",
    "sections": {
        "materials_origin": {
            "5_ASA": "Iran Najo co. (Iran)",
            "Microcrystalline_cellulose_Avicel_PH101": "Samisaz (Mashhad, Iran)",
            "Calcium_acetate": "Sigma (China)",
            "Potassium_phosphate_monobasic": "Sigma (China)",
            "Sodium_alginate": "Sigma-Aldrich (USA), Mw 80-120 kDa, mannuronate/guluronate ratio 1.56",
            "Eudragit_RS_PO": "Evonic Degussa (India Pvt. Ltd., Mumbai, India), Mw ~150 kDa",
            "Other_chemicals": "Highest commercially available analytical grade"
        },
        "experimental_design": {
            "optimization_approach": "Variation of proportions of Eudragit RS, calcium acetate, and alginate while keeping 5-ASA and Avicel fixed at 20% each. Nine formulations (119_F1-119_F9) prepared and evaluated for morphology, mechanical properties, drug release. Curing (50°C, 5h) and coating (Eudragit RS, 5% and 10% weight gain) applied to selected formulations."
        },
        "ingredients_identification": {
            "preparation_method": "Dry components mixed for 8 min, water added as granulating agent, extruded through 1mm die at 100 rpm, spheronized at 1000 rpm for 2 min. Half cured at 50°C for 5h, half dried at room temperature.",
            "absorbance_wavelengths": "pH 1.2: 302 nm; pH 6.8: 330 nm",
            "equations": {
                "sphericity": "Sphericity = 4πA / P_m^2",
                "mean_dissolution_time_MDT": "MDT = Σ(T_i ΔM_i) / ΣM_i, where T_i = (t_i + t_{i+1})/2, ΔM_i = M_{i+1} - M_i"
            }
        },
