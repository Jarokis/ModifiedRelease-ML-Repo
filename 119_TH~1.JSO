        },
        "ftir_info": {
            "instrument": "Thermo Nicolet, Madison, WI, USA",
            "wavelength_range": "400-4000 cm⁻¹",
            "sample_preparation": "Homogeneous powder of raw materials and formulations",
            "key_peaks": {
                "Eudragit_RS": "1738.3 cm⁻¹ (tertiary amine), 2926 cm⁻¹ (carboxylic acid)",
                "calcium_acetate": "1611.4 cm⁻¹, 3177.2 cm⁻¹",
                "5_ASA": "1352.8 cm⁻¹ (C-N stretch), 1649 cm⁻¹ (C=O stretch), 2500-3000 cm⁻¹ (H-bonding)",
                "sodium_alginate": "3000-3500 cm⁻¹ (O-H), 2928 cm⁻¹ (aliphatic C-H), 1620.8 and 1418.6 cm⁻¹ (carboxylate)"
            },
            "conclusion": "No chemical interaction between drug and polymers in physical mixture, cured or uncured pellets."
        },
        "pellet_fabrication_process": {
            "method": "Extrusion-spheronization",
            "equipment": {
                "extruder": "Axial extruder (Malvern, UK), die 1 mm thickness, perforations 1 mm diameter, speed 100 rpm",
                "spheronizer": "Dorsa HC 732 (Iran), cross-hatched plate, 1000 rpm for 2 min",
                "curing_oven": "Parseth (Iran), 50°C for 5 h",
                "coater": "Fluidized bed coater (Werner Glatt, Germany)"
            },
            "process_conditions": {
                "curing_temperature": "50°C",
                "curing_time": "5 hours",
                "coating_solution": "30% w/v Eudragit RS PO in isopropyl alcohol:water (9:1), triethyl citrate 10% (w/w), talc 5% (w/w)",
                "coating_inlet_air": "40°C",
                "coating_outlet_temperature": "25-35°C",
                "coating_levels": "5% and 10% w/w weight gain",
                "post_coating_drying": "2 h at 40°C"
            }
        },
        "release_properties": {
            "dissolution_apparatus": "USP apparatus I (basket method)",
            "medium_volume": "900 mL",
            "temperature": "37°C",
            "rotation_speed": "100 rpm",
            "duration": "pH 1.2: 2 h; pH 6.8: 10 h",
            "detection_wavelengths": "pH 1.2: 302 nm; pH 6.8: 330 nm",
            "release_mechanism": "For uncoated pellets: diffusion and swelling/erosion. For coated pellets: diffusion through coating layer, with pH-dependent swelling of Ca-alginate creating channels.",
            "factors_influencing_release": "pH (lower release at acidic pH, higher at pH 6.8), curing (reduces porosity and initial burst), coating level (higher coating reduces release), calcium and alginate content (higher amounts increase swelling and release at pH 6.8).",
            "release_kinetics": "Not explicitly modeled."
        },
        "pellet_properties": {
            "hardness": "Reported as crushing strength (N) in pre_compression_parameters table",
            "friability": "Not reported",
            "disintegration_time": "Not reported; pellets are matrix systems, not disintegrating",
            "dissolution_profile": "See Figures 5 and 6. Summarized: uncured and cured pellets show rapid release in pH 6.8; coated pellets (especially 119_F5 with 10% coating) show minimal release in pH 1.2 and sustained release in pH 6.8.",
            "stability": "Not reported",
            "thickness_diameter": "Size range 500-1000 μm; individual dimensions not reported",
            "weight_variation": "Not reported",
            "swelling_index": "Qualitative observation via SEM; no quantitative index reported.",
            "lag_time": "Not reported for coated pellets; in continuous dissolution, 119_F5 (10%) showed negligible release during first 2 h (acidic), then gradual release."
        },
        "experimental_data": {
            "key_results": "119_F5 formulation (25% Eudragit RS, 17.5% calcium acetate, 17.5% alginate, 20% 5-ASA, 20% Avicel) with 10% coating level provided optimal colonic delivery: minimal drug release in pH 1.2 and sustained release in pH 6.8.",
            "performance_metrics": {
                "optimal_formulation": "119_F5 with 10% coating",
                "resistance_to_acidic_conditions": "Yes, minimal release in pH 1.2",
                "release_in_alkaline_pH": "Sustained release, suitable for colonic pH <7.0"
            },
            "statistical_analysis": "Unpaired t-test for mechanical properties (cured vs uncured) at α=0.05; no significant difference for most formulations except 119_F4 and 119_F7 where curing increased hardness and elastic modulus (p<0.05)."
        }
    },
