    "experimental_data": {
      "key_results": "Kollidon SR provided better drug retarding ability and bio-adhesion compared to Eudragit RS PO. Xanthan gum acted as a bio-adhesion synergist. Higher polymer concentrations led to lower drug release and higher MDT. Bio-adhesion strength decreased with decreasing xanthan gum content.",
      "performance_metrics": {
        "release_percent_8h": "Ranged from 49.8% (F-8) to 98.2% (F-1)",
        "mdt_hrs": "Ranged from 2.947 (F-1) to 8.11 (F-8)",
        "gastro_retention_time_hrs": "Ranged from 2.050 (F-4) to 3.500 (F-5)"
      },
      "statistical_analysis": "R² values for kinetic modeling are provided. Korsmeyer-Peppas model showed high fit (R² > 0.98) for all formulations."
    }
  },
  "conclusion": {
    "summary": "Eudragit RS PO with xanthan gum is suitable for bio-adhesive sustained release dosage forms. Kollidon SR offers good sustaining properties with moderate bio-adhesion. The choice of polymer and concentration is critical for optimizing release and bio-adhesion. Further in vivo studies are recommended to confirm these findings."
  },
