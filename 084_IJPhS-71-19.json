        "release_properties": [
            {
                "batch_group": "084_MH1-084_MH5",
                "release_characteristics": "Increasing HPMC K4M concentration decreased drug release rate. 084_MH1 showed ~40% release in 1 h; higher HPMC gave more sustained release. Release profiles shown in Fig. 1.",
                "mechanism_evaluation": "Linear regression analysis used but numerical results not provided in article."
            },
            {
                "batch_group": "084_MC1-084_MC5",
                "release_characteristics": "Increasing Carbopol 934P concentration decreased release rate (Fig. 2). Carbopol's high water affinity forms a gel layer that retards drug dissolution.",
                "mechanism_evaluation": "Linear regression analysis used but numerical results not provided."
            },
            {
                "batch_group": "084_MS1-084_MS5",
                "release_characteristics": "Sodium alginate concentration increase decreased release rate. 084_MS1-084_MS3 showed high initial release (30-36% at 1 h). 084_MS4 and 084_MS5 more sustained (Fig. 3).",
                "mechanism_evaluation": "Linear regression analysis used but numerical results not provided."
            },
            {
                "batch_group": "084_T1-084_T3",
                "release_characteristics": "Combination of three polymers; increased Carbopol reduced release rate (Fig. 4).",
                "mechanism_evaluation": "Linear regression analysis used but numerical results not provided."
            },
            {
                "batch_group": "084_S1-084_S3",
                "release_characteristics": "PEG 4000 increased dissolution rate by creating pores; above 9 mg PEG effect was insignificant (Fig. 5).",
                "mechanism_evaluation": "Linear regression analysis used but numerical results not provided."
            }
        ],
