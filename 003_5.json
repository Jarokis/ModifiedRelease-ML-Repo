        },
        "equations": {
            "bulk_density": "\\(Bulk density = \\frac{Weight of granules}{Initial volume}\\)",
            "tapped_density": "\\(Tapped density = \\frac{Weight of granules}{Final volume after tapping}\\)",
            "hausner_ratio": "\\(Hausner ratio = \\frac{T_d}{B_d}\\)",
            "carr_index": "\\(Carr's Index = \\frac{T_d - B_d}{T_d} \\times 100\\)",
            "angle_of_repose": "\\(\\theta = \\tan^{-1}\\left(\\frac{h}{r}\\right)\\)",
            "higuchi": "\\(Q = K t^{1/2}\\)"
        }
    },
