{
    "article_metadata": {
        "title": "Development of Bilayer Tablets with Modified Release of Selected Incompatible Drugs",
        "journal": "Polimery w Medycynie (Polim. Med.) 2016, 46(1), 5–15",
        "authors": [
            "Neha Dhiman",
            "Rajendra Awasthi",
            "Shammy Jindal",
            "Smriti Khatri",
            "Kamal Dua"
        ],
        "drugs": [
            "Telmisartan (TMS)",
            "Simvastatin (SVT)"
        ],
        "objective": "Develop bilayer tablets with conventional release TMS and slow-release SVT to co-formulate incompatible drugs safely in one tablet.",
        "key_outcomes": {
            "summary": "TMS layer achieved ≥85% release by 45 min; SVT layer achieved ~80% by 8 h with no SVT release in first hour at pH 1.2.",
            "best_formulation_note": "003_F4 gave the highest TMS 1 h release and acceptable SVT control; maps to 003_T4/003_TMS4/003_SVT4 in this schema."
        }
    },
    "materials_origin": {
        "APIs": {
            "telmisartan": "Gift sample, Medley Pharmaceuticals Ltd., Daman, India",
            "simvastatin": "Gift sample, Lincoln Pharmaceuticals Ltd., Ahmedabad, India"
        },
        "excipients": {
            "croscarmellose_sodium": "SD Fine Chem. Ltd., Mumbai, India",
            "HPMC_K15M": "SD Fine Chem. Ltd., Mumbai, India",
            "PVP_K30": "Central Drug House (P) Ltd., Mumbai, India",
            "microcrystalline_cellulose": "Yarrow Chem Products, Mumbai, India",
            "lactose": "Yarrow Chem Products, Mumbai, India",
            "Carbopol_934P": "Yarrow Chem Products, Mumbai, India",
            "aerosil": "Listed in TMS layer; commercial source not specified"
        }
    },
    "experimental_design_for_optimization": {
        "design_type": "Eight trial formulations per layer (F1–F8) varying superdisintegrant in TMS layer; binder type/level, HPMC/Carbopol, croscarmellose/DCP in SVT layer; combined to bilayer tablets F1–F8.",
        "independent_variables_and_levels": {
            "TMS_layer": {
                "croscarmellose_sodium": [
                    "0 mg",
                    "3 mg",
                    "6 mg",
                    "9 mg"
                ]
            },
            "SVT_layer": {
                "binder_type": [
                    "starch paste 5% w/v",
                    "starch paste 3% w/v",
                    "starch paste 2% w/v",
                    "starch powder"
                ],
                "croscarmellose_sodium": [
                    "0 mg",
                    "1 mg",
                    "2 mg"
                ],
                "DCP": [
                    "0 mg",
                    "1 mg",
                    "2 mg"
                ],
                "HPMC_K15M": [
                    "56 mg",
                    "57 mg"
                ],
                "Carbopol_934P": [
                    "55 mg",
                    "56 mg"
                ],
                "PVP_K30": [
                    "26 mg"
                ]
            }
        },
        "response_variables": [
            "Granule flow indices (bulk/tapped density, Hausner ratio, Carr’s index, angle of repose)",
            "Tablet hardness, friability, thickness, weight variation, layer separation, disintegration",
            "Content uniformity (TMS, SVT)",
            "Dissolution profiles in 0.1M HCl (1 h) then pH 6.8 buffer (7 h)",
            "Release kinetics fits (zero, first order, Higuchi, Peppas) and ANOVA"
        ],
        "analysis_methods": {
            "kinetics_models": [
                "Zero order",
                "First order",
                "Higuchi",
                "Korsmeyer-Peppas"
            ],
            "statistics": "Two-way ANOVA with Bonferroni post-tests; p < 0.0001 threshold"
        }
    },
    "ingredients_identification_and_analytical_setup": {
        "UV_spectrophotometry": {
            "instrument": "UV 3000+ (Labindia Instruments, Mumbai)",
            "lambda_max_nm": {
                "TMS": 290,
                "SVT": 238
            },
            "media": {
                "TMS": "0.1M HCl (pH 1.2)",
                "SVT": "Phosphate buffer (pH 6.8)"
            },
            "scan_range_nm": "200–400",
            "multi_component_analysis": true
        },
        "FTIR": {
            "instrument": "IR Affinity-1 (Shimadzu, Japan)",
            "method": "KBr disc",
            "scan_range_cm_minus1": "4000–400",
            "resolution_cm_minus1": 4,
            "compatibility_findings": "Layers individually show preserved API characteristic peaks; physical mixture of layers shows reduced intensity/shifted/disappeared peaks, evidencing incompatibility when blended.",
