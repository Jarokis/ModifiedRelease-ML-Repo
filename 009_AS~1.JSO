{
    "sections_mapping": {
        "abstract": [
            "Study aim, formulation sets (009_F1–009_F4 polymer ratios; 009_F5–009_F9 SLS levels), dissolution overview, release models, and key conclusion (009_F6 best) [attached_file:1]"
        ],
        "introduction": [
            "Clinical rationale for sustained release carvedilol, solubility context, and objective of using HPMC matrices with SLS [attached_file:1]"
        ],
        "materials_and_methods": [
            "Materials origin (vendors), tablet preparation (direct compression), compression device/force/time/punch, blend and tablet tests, UV-Vis calibration (241 nm, absorbance table), dissolution setup (USP II, 0.1 N HCl pH 1.2, 37±0.05°C, 100 rpm, 24 h), release models and equations, MDT equation [attached_file:1]"
        ],
        "results_and_discussion": [
            "Pre-compression (reported as ranges), tablet properties (reported as ranges), 009_F1–009_F4 and 009_F5–009_F9 dissolution tables and figures, kinetic parameters (009_F5–009_F9), MDT and fractional dissolution times, mechanism interpretation (diffusion + erosion) and selection of 009_F6 [attached_file:1]"
        ],
        "conclusion": [
            "Summary of successful once-daily sustained-release matrix development and best formulation note [attached_file:1]"
        ]
    },
    "materials_origin": {
        "api": "Carvedilol phosphate (gift sample), Beximco Pharmaceuticals Limited, Bangladesh [attached_file:1]",
        "excipients": [
            "Methocel K4M CR, Methocel K15M CR, Avicel PH101 (Dow Chemical’s Asia Pvt., India) [attached_file:1]",
            "Starch 1500 (Colorcon, USA) [attached_file:1]",
            "Sodium lauryl sulfate (Sigma-Aldrich Chemie GmbH, Germany) [attached_file:1]",
            "Talc (S.D. Fine-Chem Limited, Mumbai, India) [attached_file:1]",
            "Magnesium stearate (Novochem GmbH, Germany) [attached_file:1]"
        ],
        "solvents_and_grade": "Reagent-grade chemicals; distilled water used throughout [attached_file:1]"
    },
    "experimental_design_for_optimization": {
        "overview": "Two-stage optimization: 009_F1–009_F4 varied HPMC K4M/K15M ratio to sustain 24 h; 009_F5–009_F9 fixed polymer ratio and varied SLS (1.0–2.0%) to enhance dissolution of poorly soluble carvedilol [attached_file:1]",
        "sets": [
            {
                "name": "009_F1–009_F4",
                "factor": "HPMC K15M level while K4M fixed (matrix polymer ratio) [attached_file:1]",
                "levels_mg": [
                    {
                        "K4M": 45,
                        "K15M": 45
                    },
                    {
                        "K4M": 45,
                        "K15M": 39
                    },
                    {
                        "K4M": 45,
                        "K15M": 33
                    },
                    {
                        "K4M": 45,
                        "K15M": 27
                    }
                ],
                "objective": "Optimize polymer composition to avoid burst and sustain release up to 24 h [attached_file:1]"
            },
            {
                "name": "009_F5–009_F9",
                "factor": "SLS percentage with fixed polymers (K4M 45 mg, K15M 33 mg) [attached_file:1]",
                "levels_percent": [
                    1.0,
                    1.25,
                    1.5,
                    1.75,
                    2.0
                ],
                "objective": "Increase dissolution rate due to poor aqueous solubility while matching theoretical once-daily profile [attached_file:1]"
            }
        ],
        "theoretical_once_daily_release_target": {
            "t1h": "NMT 25% [attached_file:1]",
            "t4h": "30–45% [attached_file:1]",
            "t8h": "45–60% [attached_file:1]",
            "t12h": "60–70% [attached_file:1]",
            "t24h": "NLT 90% [attached_file:1]"
        }
    },
    "ingredients_identification_uv_vis": {
        "how_prepared": "10 mg carvedilol in 50 mL flask; add 1 mL methanol, sonicate 5 min; cool; make to volume with distilled water; filter (Whatman 42 then 0.45 μm); prepare 1–8 μg/mL standards [attached_file:1]",
        "instrument_and_wavelength": "Double-beam UV-Vis spectrophotometer (Shimadzu, Japan) at 241 nm [attached_file:1]",
        "absorbance_table": [
            {
                "conc_ug_per_mL": 1.0,
                "absorbance": 0.112
