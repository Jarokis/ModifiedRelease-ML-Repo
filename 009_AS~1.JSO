        ],
        "equations_used_in_methods": [
            "Angle of repose: \\( \\theta = \\tan^{-1}(h/r) \\) [attached_file:1]",
            "Loose bulk density: \\( \\mathrm{LBD} = \\frac{\\text{mass}}{\\text{bulk volume}} \\) [attached_file:1]",
            "Tapped bulk density: \\( \\mathrm{TBD} = \\frac{\\text{mass}}{\\text{tapped volume}} \\) [attached_file:1]",
            "Carr’s index: \\( \\%CI = \\frac{(\\mathrm{TBD}-\\mathrm{LBD})\\times 100}{\\mathrm{TBD}} \\) [attached_file:1]",
            "Hausner ratio: \\( H = \\frac{\\mathrm{TBD}}{\\mathrm{LBD}} \\) [attached_file:1]",
            "Porosity: \\( \\%\\,\\varepsilon = \\frac{V_{\\text{bulk}} - V}{V_{\\text{bulk}}}\\times 100 \\) [attached_file:1]",
            "Korsmeyer–Peppas: \\( \\frac{M_t}{M_\\alpha} = k t^{n} \\) with mechanism by n [attached_file:1]",
            "Mean dissolution time: \\( \\mathrm{MDT} = \\left(\\frac{n}{n+1}\\right)k^{-1/n} \\) [attached_file:1]"
        ]
    },
