    "experimental_data": {
        "key_results": [
            "All multicoated tablets showed substantial drug release (>10%) in simulated gastric fluid (pH 1.2), indicating failure to achieve colon‑targeted delivery.",
            "Probiotic concentration did not significantly affect the release profile for any coating polymer.",
            "Tablets coated with alginate, chitosan, or xanthan gum all exhibited similar release patterns, with nearly complete release by 12 hours.",
            "The secondary coating (Eudragit L100/S100) did not adequately protect against release in acidic conditions."
        ],
        "performance_metrics": {
            "hardness_range": "11.9–15.0 kP for coated tablets",
            "friability": "All <0.05%, meeting USP requirements (<1%)",
            "weight_variation": "All within acceptable limits (acceptance value <15%)",
            "content_uniformity": "All within 90–110% of label claim",
            "assay": "All between 101.6% and 107.6%"
        },
        "statistical_analysis": "Data are presented as mean ± standard deviation (SD) for n=3 (dissolution) or n=10–20 (tablet properties). No inferential statistics (e.g., ANOVA) were reported.",
        "zero_and_first_order_release": "Not calculated.",
        "swelling_study": "Not performed.",
        "lag_time": "Not defined; early release observed from 15 minutes in acidic medium."
    },
    "notes": "The dissolution data for some time points (especially at 720 min) are incomplete in the PDF; values were extracted as available. The table for xanthan gum coated F1X, F2X, F3X likely includes all three formulations based on text, but some values are truncated. The authors concluded that the formulation was not optimal for colon targeting due to premature release."
