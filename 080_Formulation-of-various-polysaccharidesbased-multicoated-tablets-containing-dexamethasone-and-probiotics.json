    "experimental_design": {
        "description": "Three core tablet formulations (080_F1, 080_F2, 080_F3) with different probiotic concentrations (16%, 40%, 0% of core weight) were prepared by wet granulation. Each core was coated with a primary coating of either sodium alginate (A), chitosan (C), or xanthan gum (X), followed by a secondary coating of Eudragit L100:S100 (1:4). Total of 9 coated formulations (F1A, F2A, F3A, F1C, F2C, F3C, F1X, F2X, F3X).",
        "independent_variables": {
            "probiotic_concentration": {
                "levels": [
                    "0% (080_F3)",
                    "16% (080_F1)",
                    "40% (080_F2)"
                ],
                "note": "Percentage of total core weight (100 mg) occupied by probiotics (L. acidophilus and B. longum in 1:1 ratio)."
            },
            "primary_coating_polymer": {
                "levels": [
                    "sodium alginate (A)",
                    "chitosan (C)",
                    "xanthan gum (X)"
                ]
            }
        },
        "dependent_variables": [
            "Granule flow properties",
            "Tablet hardness, friability, weight variation, thickness, diameter",
            "Drug content and uniformity",
            "In vitro drug release profile"
        ]
    },
