    "experimental_design": {
        "optimization_factors": [
            "Polymer type (XG, SA, LAGG, HM Pectin)",
            "Polymer amount (45% w/w or 72% w/w of total tablet weight)",
            "Excipient ratio (Avicel 102 : PVP k30 in proportions 100:0, 75:25, 50:50, 25:75, 0:100)"
        ],
        "response_variables": [
            "Hardness",
            "Friability",
            "Thickness",
            "Diameter",
            "Weight variation",
            "Swelling",
            "In vitro drug dissolution"
        ]
    },
    "ingredients_identification": {
        "preparation_method": "Direct compression method. Components mixed by geometric dilution with mortar and pestle for 15 min, passed through sieve number 20, then magnesium stearate added as lubricant.",
        "dsc_results": "ITOP showed sharp endothermic peak at 192.84°C. No significant changes with pectin, LAGG, XG, Avicel 102. Slight non-significant shift with PVP k30 and SA, not indicating incompatibility.",
        "absorbance_wavelength": "258 nm",
        "drug_content_equation": "Content uniformity: Three tablets crushed, dissolved in 50 ml 0.1N HCl, stirred for 10 min, centrifuged, supernatant diluted and measured.",
        "swelling_index_equation": "% Water uptake = ((W2 - W1) / W1) × 100, where W1 = initial weight, W2 = weight after swelling."
    },
