{
    "article_info": {
        "title": "Design and development of gastroretentive drug delivery system of ciprofloxacin hydrochloride",
        "authors": "Vibin Bose R, Jeganath S, Ramya Sree K, Sherni Prithiba Jhansi Rani S",
        "journal": "Asian Journal of Pharmaceutics and Clinical Research",
        "year": 2018,
        "volume": 11,
        "special_issue": 4,
        "pages": "1-6",
        "doi": "http://dx.doi.org/10.22159/ajprc.2018.v11s4.31722"
    },
