        "ciprofloxacin_hcl": "Gift sample from Micro Labs, Hosur, India",
        "hpmc_k4m": "Loba Chemicals, Mumbai, India",
        "eudragit_100s": "Loba Chemicals, Mumbai, India",
        "guar_gum": "Loba Chemicals, Mumbai, India",
        "sodium_bicarbonate_(saleratus)": "S.D. Fine Chemicals, Mumbai, India",
        "citric_acid": "S.D. Fine Chemicals, Mumbai, India",
        "starch": "S.D. Fine Chemicals, Mumbai, India",
        "magnesium_stearate": "S.D. Fine Chemicals, Mumbai, India"
    },
    "experimental_design": {
        "preparation_method": "Wet granulation technique",
        "gas_generating_agents": "Sodium bicarbonate and citric acid",
        "binder": "Starch mucilage",
        "independent_variables": {
            "polymers": [
                "HPMC K4M",
                "Eudragit 100S",
                "Guar gum"
            ],
            "levels": "Different combinations as per Table 1 (see batch compositions)"
        },
        "dependent_variables": [
            "Buoyancy lag time",
            "Total floating time",
            "Drug release profile",
            "Release kinetics"
        ]
    },
    "process_parameters": {
        "sieving": {
            "api": "Sieve No. 20",
            "excipients": "Sieve No. 40",
            "magnesium_stearate": "Sieve No. 60",
            "wet_granulation": "Sieve No. 16",
            "dried_granules": "Sieve No. 20"
        },
        "mixing": "Geometric mixing followed by blending for 10 min",
        "drying": "Hot air oven at 40°C for 2 hours",
        "compression_device": "Tablet punching machine (specific model not stated)",
        "compression_pressure": "Not specified",
        "hardness_tester": "Monsanto hardness tester (referred as 'monastano')",
        "friability_tester": "Roche Friabilator",
        "dissolution_apparatus": "USP Type II (paddle), 50 rpm, 900 mL 0.1N HCl, 37±0.5°C",
        "uv_absorbance_wavelength": "277 nm"
    },
