{
  "article_title": "The Effect of Acid pH Modifiers on the Release Characteristics of Weakly Basic Drug from Hydrophilic-Lipophilic Matrices",
  "authors": ["Kateřina Dvořáčková", "Petr Doležel", "Eliška Mašková", "Jan Muselík", "Martina Kejdusová", "David Vetchý"],
  "publication_year": 2013,
  "sections": {
    "abstract": "The solubility of weakly basic drugs within GI tract leads to pH-dependent release. The study aimed to prepare hydrophilic-lipophilic (hypromellose-montanyloyl wax) matrix tablets ensuring pH-independent delivery of verapamil-HCl by incorporating citric, fumaric, or itaconic acids. Dissolution studies used changing pH (2 h pH 1.2, then 10 h pH 6.8). Microenvironment pH was measured. Full factorial design and PLS-2 regression were used. Acidifiers increased drug release rate. Concentration and strength of acidifier were crucial (p<0.01); solubility did not influence effects except surface pH at 480 min.",
    "introduction": "Discusses pH-dependent solubility of weakly basic drugs and strategies to achieve pH-independent release, including incorporation of organic acids. Focus on verapamil-HCl, HPMC-montanylcol wax matrices.",
    "materials_and_methods": "Describes materials, granulation, tablet compression, dissolution testing, pH measurement, and statistical analysis.",
    "results_and_discussion": "Presents dissolution profiles, similarity factors, release kinetics, gel layer pH, and statistical evaluation.",
    "conclusion": "Incorporation of 100 mg citric or fumaric acid improved pH-independent release. Concentration and pKa were crucial; solubility not significant."
  },
  "materials_origin": {
    "verapamil_hydrochloride": "Chemos, Regenstauf, Germany",
    "HPMC_K4M": "Colorcon Limited, Dartford, Great Britain",
    "microcrystalline_cellulose_Avicel_PH101": "FMC Biopolymers, Rockland, USA",
    "montanylcol_wax": "Zentiva, Prague, Czech Republic",
    "citric_acid": "Sigma-Aldrich, GmbH, Steinheim am Albuch, Germany",
    "fumaric_acid": "Sigma-Aldrich, GmbH, Steinheim am Albuch, Germany",
    "itaconic_acid": "Sigma-Aldrich, GmbH, Steinheim am Albuch, Germany",
    "magnesium_stearate": "Peter Greven, Bad Munstereifel, Germany",
    "colloid_silica": "Degussa, Vicenza, Italy"
  },
  "experimental_design_for_optimization": {
    "method": "Full factorial design and partial least squares PLS-2 regression",
    "independent_variables": ["acid type (citric, fumaric, itaconic)", "acid concentration (50 mg vs 100 mg)", "pKa", "solubility"],
    "dependent_variables": ["drug release at 360 min", "drug release at 480 min", "surface pH of gel layer at 360 min", "surface pH of gel layer at 480 min"],
    "software": "Unscrambler X v.10.2 (Camo software)"
  },
  "ingredients_identification": {
    "particle_size_measurement": "Optical microscope (DN 45, Lambda, Prague) with CCD camera (Alphaphot, Nikon), Ia32 software. Mean diameters: citric 200.1 μm, fumaric 179.3 μm, itaconic 190.6 μm.",
    "drug_content_analysis": "Spectrophotometric method at 278 nm (Lambda 25, Perkin Elmer, Wellesley, USA).",
    "dissolution_analysis": "UV spectrophotometer at 278 nm for VH."
  },
