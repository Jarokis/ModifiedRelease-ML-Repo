    "experimental_design_for_optimization": {
        "design_type": "Box-Behnken statistical design, three-factor three-level",
        "independent_variables_and_levels": {
            "mass_of_poly_D_L_lactide_mg": {
                "lower": 937.5,
                "upper": 1102.5
            },
            "mass_of_magnesium_stearate_mg": {
                "lower": 7.5,
                "upper": 22.5
            },
            "mass_of_Kollidon_SR_mg": {
                "lower": 75.0,
                "upper": 225.0
            }
        },
        "responses": {
            "fractional_mass_increase_FMI_after_7_days_in_SVF": "Minimize",
            "hardness_H_N": "Maximize",
            "fractional_drug_release_FDR_after_7_days_in_SVF": "Minimize"
        },
        "number_of_formulations": 15,
        "optimization_software": "MINITAB V15",
        "composite_desirability_D": 0.997,
        "optimized_independent_variables": {
            "mass_of_PDLL_mg": 937.5,
            "mass_of_MS_mg": 7.5,
            "mass_of_KSR_mg": 75.0
        },
        "optimized_predicted_responses": {
            "FMI": 0.279,
            "hardness_N": 21.8,
            "FDR": 0.401
        },
        "regression_equations": {
            "FMI": "FMI = 1.616 - 0.002[PDLL] + 0.668[MS] - 0.001[KSR] (R²=87.3%)",
            "Hardness": "H = -14.465 + 0.101[PDLL] - 0.706[MS] - 0.109[KSR] - 0.005[MS×MS] + 0.001[PDLL×MS] + 0.001[MS×KSR] (R²=61.7%)",
            "FDR": "FDR = 3.964 - 0.008[PDLL] + 0.009[MS] + 0.007[KSR] (R²=77.9%)"
        }
    },
    "ingredients_identification": {
        "preparation_of_AZT_loaded_SMMs": {
            "method": "Cross-linking emulsion technique",
            "aqueous_phase": "Ca²⁺ (0.01 M, 3.89 mL), pectin (270 mg), porcine gastric mucin (30 mg), PEG 400 (0.1 mL), AZT (300 mg)",
            "oil_phase": "Cyclohexane",
            "optimized_parameters": {
                "ultrasonication_time_min": 6.28,
                "drug_polymer_ratio": "1:1",
                "surfactant_Span_85_concentration_percent_v_v": 1.64
            }
        },
        "composite_polymeric_caplet_preparation": {
            "blending": "PDLL, KSR, MS, AZT-loaded SMMs (20% w/w), Carbopol 974P NF (1% w/w) blended for 5 min",
            "compression": "Direct compression on hydraulic Carver press at 2.5 tons force",
            "caplet_dimensions_optimized": {
