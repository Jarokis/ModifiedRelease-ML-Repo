                "width_mm": 10,
                "thickness_mm": 6
            }
        },
        "absorbance_for_drug_release": {
            "wavelength_nm": 267,
            "instrument": "Nanophotometer"
        },
        "equations_used": {
            "mean_dissolution_time_MDT": "MDT = Σ(t_t * M_t) / M_e",
            "dissolution_efficiency_DE": "DE = (∫₀ᵗ y dt / y₁₀₀) × 100%",
            "difference_factor_f1": "f1 = (Σ|R_t - T_t| / ΣR_t) × 100%",
            "similarity_factor_f2": "f2 = 50 log { [1 + (1/n) Σ W_t (R_t - T_t)²]⁻⁰·⁵ × 100 }",
            "percent_dimensional_increase": "% dimensional increase = ((D₂ - D₁)/D₁) × 100",
            "matrix_resilience": "Resilience(%) = (∫₁³ f(t)dt_descending / ∫₁³ f(t)dt_ascending) × 100"
        }
    },
