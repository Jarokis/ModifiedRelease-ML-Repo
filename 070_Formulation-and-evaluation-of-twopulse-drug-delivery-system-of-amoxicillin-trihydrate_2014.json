        "experimental_design": "pH-controlled two-pulse delivery system. Core tablets (216 mg, 200 mg amoxicillin) were compression-coated with barrier layers containing HPMC (100, 400, 4000 cps) and spray-dried lactose (SDL) as pore former in varying ratios. Final two-pulse inlay tablets combined an immediate-release outer layer (300 mg amoxicillin) and the barrier-coated core (200 mg amoxicillin). Batches 070_C1–070_C12 represent the compression-coated tablets (core + barrier layer).",
        "ftir_dsc_summary": {
            "ftir": "Drug-excipient compatibility confirmed. Characteristic peaks: broad OH peak ~3300 cm⁻¹, C=O (lactam) ~1770 cm⁻¹, aromatic C-H ~1500 cm⁻1.",
            "dsc": "Endothermic peaks: pure amoxicillin 298.9 °C, formulation (070_C4) 294.4 °C; negligible shift, no interaction."
        },
        "common_process_parameters": {
            "core_tablet_compression": {
                "equipment": "10-station rotary tablet machine (Rimek mini press, Mumbai)",
                "punch_size": "9 mm standard concave",
                "hardness": "42 ± 0.50 N"
            },
            "compression_coating": {
                "method": "Compression coating using die cavity",
                "punch_size": "11 mm",
                "compression_force": "145 ± 0.5 N",
                "core_to_coat_ratio": "1:2 (core 216 mg, coat 432 mg)"
            },
            "final_two_pulse_tablet": {
                "method": "Inlay tablet by compression coating",
                "die_size": "12.7 mm standard concave",
                "hardness": "190 ± 0.5 N"
            }
        },
        "stability_study": {
            "conditions": "40 ± 2 °C, 75 ± 5% RH for 3 months",
            "results": "No significant difference in drug release (95% CI). Drug content 48.14 ± 0.35% (likely for barrier-coated core). Hardness within limits (6.4 ± 0.23 kg/cm²)."
        },
        "statistical_analysis": "One-way ANOVA with Tukey's post hoc test, confidence limit 95%."
    },
