        "total_formulations": 45
    },
    "dose_calculation": {
        "equation": "D_t = D_n * (1 + 0.693 * T_d / t_{1/2})",
        "parameters": {
            "D_n": "4 mg (immediate release dose)",
            "t_half": "2.5 hours",
            "T_d": "24 hours (controlled release duration)",
