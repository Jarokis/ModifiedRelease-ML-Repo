        "key_findings": {
            "E10ST_formulations": "Unable to control release; nearly 100% released within 4 hours.",
            "low_polymer_formulations": "Polymer ≤25% (K4M5, K100M5, E10FP3, 120_KSR5): >90% released in 4 hours.",
            "polymer_30%": "K4M3, K100M3, KSR3: ~80% released; E10FP9: 76% released.",
            "controlled_release_formulations": "K4M2 (50% polymer), K100M9 (40% polymer), E10FP2 (40% polymer), 120_KSR2 (55% polymer) showed: 45-53% in 4h, 82-85% in 8h, 94-99% in 24h.",
            "K100M2": "50% polymer, ~80% released in 24h (incomplete)."
        }
    },
    "process_parameters": {
        "compression_device": "Manually operated single punch tablet press (Korsch Erweka, Frankfurt, Germany)",
        "punch_shape": "Convex round shaped",
        "compression_pressure_range": "Not specified, but tablet weights ranged 96-126 mg",
        "blending_method": "Tumbling method in a polybag for 8-10 minutes",
        "sieve_size": "40-mesh"
    },
    "quantification_method": {
        "technique": "HPLC",
        "mobile_phase": "Acetonitrile : buffer solution of sodium 1-pentanesulfonate (4:1)",
