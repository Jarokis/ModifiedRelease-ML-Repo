            "F4_25%K4M": "Fastest release among different HPMC amounts.",
            "F5_30%K4M": "Faster release than 054_F6 and F7.",
            "F6_40%K4M": "Slower release than F5.",
            "F7_50%K4M": "Slowest release among K4M amounts.",
            "F8_80:20_coated": "Initial lag time (0.5-1h) followed by linear release.",
            "F10_60:40_coated": "Lag time eliminated, but release rate decreased in final period compared to F8.",
            "F11_3.5%WG": "Less obvious lag time.",
            "F12_5.5%WG": "Longer lag time and slower release than F11.",
            "F13_7.5%WG": "Longest lag time and slowest release among weight gains."
