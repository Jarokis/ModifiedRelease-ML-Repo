    "ftir_spectral_measurements": "Information not provided in the article.",
    "tablet_fabrications": {
        "general_method": "Core tablets were fabricated by direct compression using a single punch press (Beijing Gylongli Sci. & Tech. Co., Ltd., Beijing, China). Powders were mixed in a three-dimensional blender (WAB Machinery Co., Ltd., Shenzhen, China). Tablet dimensions were 8.8 mm standard biconvex round.",
        "hardness": "Measured using a hardness tester (YD-35, Tianda Tianfa Technology Co., Ltd., Tianjin, China) (n=6).",
        "friability": "Determined using a friabilator (FAB-2, Tianda Tianfa Technology Co., Ltd., Tianjin, China) with 22 tablets at 25 rpm for 4 min (n=3).",
        "weight_variation": "Tablets were accurately weighed by an electronic balance (BSA223S-CW, Sartorius, Germany). Content uniformity was up to standard.",
        "thickness_and_diameter": "Not explicitly measured, but tablet size is stated as 8.8 mm diameter.",
        "density_of_formulation": "Information not provided.",
        "drug_content": "Determined by UV/Vis spectrophotometry. Content uniformity was reported to be up to standard.",
        "consolidation_index": "Information not provided."
    },
    "process_parameters": {
        "compression_process": {
            "device": "Single punch press (Beijing Gylongli Sci. & Tech. Co., Ltd., Beijing, China)",
            "pressure": "Not specified, but adjusted to achieve a target hardness range of 80-100 N.",
            "tablet_size": "8.8 mm standard biconvex round"
        },
        "coating_process": {
            "device": "Fully perforated coating pan (LABCOAT I, O'Hara Technologies, Canada)",
            "nozzle_size": "0.8 mm",
            "inlet_temperature": "56-58 °C",
            "exhaust_temperature": "40-43 °C",
            "bed_temperature": "39-42 °C",
            "air_flow_velocity": "80 m³/h",
            "atomization_pressure": "1.2 bar",
            "spray_rate": "1.4-1.6 g/min",
            "pan_speed": "9 rpm",
            "curing_conditions": "60°C for 6 hours in an oven",
            "coating_solution_solids_content": "10% (w/w)"
        }
    },
