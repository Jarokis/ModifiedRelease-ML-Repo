    "tablet_properties": {
        "general_properties": "All core and coated tablets were white in color. Weight variation and content uniformity were up to standard. Friability for all formulations was less than 1%.",
        "hardness": "For HPMC K4M-based core tablets, the hardness was set in the range of 80-100 N to ensure robustness for subsequent coating. Individual batch data for other formulations not specified.",
        "friability": "Less than 1% for all formulations.",
        "disintegration_time": "Information not provided, as these are extended-release tablets not intended to disintegrate.",
        "dissolution_profile": "See 'release_properties' for kinetics and 'experimental_data' for parameters.",
        "stability": "Selected coated tablets (K4M-based, 80:20, 3.5% WG) showed no obvious change in appearance, drug content, or release rate after 10 days at 60°C, 75%±5% RH, and 4500lx±500lx.",
        "thickness": "Not explicitly measured.",
        "weight_variation": "Up to standard, but specific data not provided.",
        "lag_time": "Coated tablets with 80:20 Surelease:Opadry ratio and 3.5% WG exhibited an initial lag time of about 0.5-1 hour in vitro. In vivo, lag time increased as coating permeability decreased."
    },
