{
    "materials_origin": {
        "ambroxol_hydrochloride": "Wuhan Yuancheng Technology development Co., Ltd. (Hubei, China)",
        "hypromellose": "Shanghai Colorcon Co., Ltd. (Shanghai, China) (METHOCEL™ K100LV/K4M Premium DC2 and K15M Premium CR)",
        "ethylcellulose_dispersion": "Shanghai Colorcon Co., Ltd. (Shanghai, China) (Surelease®, E-7-19020)",
        "hpmc_coating": "Shanghai Colorcon Co., Ltd. (Shanghai, China) (Opadry®, OY-29020)",
        "mannitol": "Shanghai InnoPolymer Pharmaceutical Tech.Co., Ltd. (Shanghai, China) (PEARLITOL® 200 SD)",
        "microcrystalline_cellulose": "Shanghai Fenghong Pharmaceutical Excipients Tech. Co., Ltd. (Shanghai, China) (Avicel® 054_PH102)",
        "colloidal_silicon_dioxide": "Shanghai Fenghong Pharmaceutical Excipients Tech. Co., Ltd. (Shanghai, China) (Aerosil® 200 Pharma)",
        "magnesium_stearate": "Shanghai Chineway Pharmaceutical Tech. Co., Ltd. (Shanghai, China) (Hyqual®)"
    },
    "experimental_design_for_optimization": {
        "ingredients_identification": "The study used Ambroxol Hydrochloride (AH) as the active pharmaceutical ingredient (API). Hypromellose (HPMC) of various viscosities (K100LV, K4M, K15M) was used as the primary matrix material. Surelease® (aqueous ethylcellulose dispersion) was used as the insoluble film coating polymer, and Opadry® (HPMC-based) was used as a pore-former in the coating. Other excipients included MCC, mannitol, colloidal silicon dioxide, and magnesium stearate.",
        "preparation_method": "Core tablets were prepared by direct compression of a dry mixture of API, HPMC, fillers, and glidant, followed by lubrication and compression. Coated tablets were prepared by spraying an aqueous dispersion of Surelease® and Opadry® onto the core tablets in a coating pan.",
        "results": "The study successfully produced robust matrix tablets with uniform film coatings. Drug release rates could be tailored by adjusting HPMC viscosity/amount, pore-former ratio in the coating, and coating weight gain. Coated tablets exhibited an initial lag time followed by near zero-order release kinetics. In vivo studies in beagle dogs showed a prolonged lag time with decreased coating membrane permeability, correlating with in vitro release.",
        "equation": "Zero-order: Mt/M∞ = kt; Power Law: Mt/M∞ = ktⁿ",
        "absorbance": "In vitro drug content was determined by UV/Vis spectrophotometry at a wavelength of 244 nm (USP Apparatus II) or 307 nm (USP Apparatus III)."
    },
