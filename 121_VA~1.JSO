        "swelling_study": {
            "method": "Tablets placed in 5 mL 0.08 M acetic buffer pH 4.5 at 37±0.5°C, weighed at intervals",
            "results": {
                "121_F1": "Rapid initial swelling, 50% weight loss after 2h due to erosion",
                "121_F2": "Highest swelling index (SI) 5.45 at 30 min; compact, slight drop at end",
                "121_F3": "SI 3.81 at 30 min; compact",
                "121_F4": "Not tested"
            },
            "order": "121_F2 > 121_F1 > 121_F3 at 30 min"
        },
        "residence_time": {
            "method": "Modified USP disintegration tester, porcine vaginal mucosa, pH 4.5 buffer, 37°C",
            "results": "121_F2 and 121_F3 significantly longer than control and 121_F1; correlated with chitosan concentration (Fig. 5A)"
        },
        "mucoadhesive_properties": {
            "method": "Texture analyser TA.XT.Plus, 5 kg load cell, contact force 1 N for 100 s, separation rate 0.1 mm/s",
            "substrates": "Porcine vaginal mucosa, 30% gelatin discs, 10% mucin gel on cellulose",
            "results": {
                "121_F1": "Lower F_max and W_ad",
                "121_F2": "Intermediate; plateau in mucoadhesion (not significantly different from 121_F3)",
                "121_F3": "Highest values: F_max = 0.747 ± 0.188 N (median 0.671), W_ad = 1021.7 ± 365 μJ (median 961.3) on porcine mucosa",
                "control": "Significantly lower than 121_F2/121_F3"
            },
            "note": "Gelatine discs showed better correlation to porcine mucosa and higher reproducibility than mucin gel."
        },
        "statistical_analysis": {
            "tests": "Kruskal-Wallis and Mann-Whitney U-test, Statistica 10.0",
            "significance_level": "p < 0.05",
            "key_findings": "No significant difference in mucoadhesion between 121_F2 and 121_F3 (p > 0.05); 121_F2 and 121_F3 significantly better than control and 121_F1"
        },
        "performance_metrics": {
            "best_formulation": "121_F2 (25% chitosan) – best balance of mucoadhesion, sustained release, and mechanical properties.",
            "commercial_comparison": "121_F2 and 121_F3 provide prolonged residence time and retarded release vs. commercial vaginal tablets."
        }
