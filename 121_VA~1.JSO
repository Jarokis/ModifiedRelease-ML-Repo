{
    "article_summary": {
        "title": "Vaginal Chitosan Tablets with Clotrimazole—Design and Evaluation of Mucoadhesive Properties Using Porcine Vaginal Mucosa, Mucin and Gelatine",
        "authors": "Emilia Szymańska, Katarzyna Winnicka, Aleksandra Amelian, Urszula Cwalina",
        "journal": "Chem. Pharm. Bull. 62(2) 160-167 (2014)",
        "objective": "Develop mucoadhesive vaginal tablets with clotrimazole using chitosan to prolong drug residence time."
    },
    "sections": {
        "abstract": "Pages 1-2",
        "introduction": "Page 1",
        "experimental": "Pages 2-3",
        "results_and_discussion": "Pages 3-7",
        "conclusion": "Page 7"
    },
    "materials_origin": {
        "chitosan": {
            "type": "Medium molecular weight (MMW)",
            "deacetylation_degree": "75-85%",
            "viscosity": "200 cP (1% solution in 1% acetic acid)",
            "supplier": "Sigma-Aldrich, Steinheim, Germany"
        },
        "clotrimazole": {
            "source": "Gift from Ziaja Ltd. (Gdansk, Poland)"
        },
        "excipients": {
            "Prosolv_SMCC_50": "silicified microcrystalline cellulose, JRS Pharma, Rosenberg, Germany",
            "Pruv": "sodium stearyl fumarate, JRS Pharma, Rosenberg, Germany",
            "Tablettose_80": "spray-dried lactose, Cardinal Pharma Ltd., Lodz, Poland",
            "potato_starch": "Galfarm, Krakow, Poland"
        },
        "porcine_vaginal_mucosa": {
            "source": "Large White Pigs (~200 kg) from Bost slaughterhouse (Turosn Koscielna, Poland)",
            "preparation": "Frozen at -20°C immediately after sacrifice, thawed at ambient temperature, cut into 2 cm long, 2 mm thick pieces"
        },
        "other_chemicals": {
            "acetic_acid_80%": "Chempur, Piekary Slaskie, Poland",
            "buffers": "sodium acetate, potassium dihydrogen phosphate, sodium hydroxide, disodium hydrogen phosphate from Chempur",
            "methanol": "HPLC grade, Merck, Darmstadt, Germany",
            "water": "distilled, passed through Milli-Q Reagent Water System"
        }
    },
    "experimental_design_for_optimization": {
        "method": "Preliminary experiments with constant drug and chitosan amounts, varying excipient blends to determine suitable weight ratio. Direct compression used.",
        "optimization_criteria": "Mechanical stability, mucoadhesive properties, prolonged release.",
        "selected_formulations": "121_F1, 121_F2, 121_F3 (121_F4 mechanically unstable)"
    },
    "ingredients_identification": {
        "preparation_of_tablets": "Direct compression using single punch eccentric tablet press EP-1 with 12 mm flat-faced punches at 20 rpm. Blended powder mixed in mortar, sieved through 300 μm sieve.",
        "characterization_methods": {
            "HPLC": {
                "conditions": "Isocratic, Zorbax Eclipse XDB-C18 column (4.6×150 mm, 5 μm), mobile phase methanol-phosphate buffer pH 7.4 (4:1 v/v), flow rate 1.0 mL/min, UV detection 210 nm, column temp 25°C, injection 20 μL, retention time 5.2 min, calibration 1-100 μg/mL"
            },
            "SEM": "Hirox SH-3000 mini-SEM, 15 kV, back-scattered electrons, low vacuum",
            "DSC": "Q2000 (TA Instruments), 30-280°C at 30°C/min under nitrogen"
        },
        "equations_used": {
            "swelling_index": "SI = (W2 - W1)/W1",
            "release_kinetics": {
                "zero_order": "f_t = k0 × t",
                "first_order": "f_t = f_max × (1 - exp(-k1 t))",
                "higuchi": "f_t = K √t",
                "korsmeyer_peppas": "f_t = k_k × t^n"
            }
        }
    },
