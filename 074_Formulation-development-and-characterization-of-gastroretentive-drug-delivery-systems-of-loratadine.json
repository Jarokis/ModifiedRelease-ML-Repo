{
    "study_title": "FORMULATION DEVELOPMENT AND CHARACTERIZATION OF GASTROTENTIVE DRUG DELIVERY SYSTEMS OF LORATADINE",
    "authors": "SRINU NAIK SAPAVATU, RAJENDRA KUMAR JADIP",
    "journal": "International Journal of Applied Pharmaceutics",
    "year": 2019,
    "sections": {
        "abstract": "The main objective of the research work is to develop a single unit non-effervescent drug delivery system of Loratadine (LTD) by direct compression process to prolong the gastric residence time (GRT). LTD non-effervescent floating tablets were prepared with different polymers like hydroxypropyl methylcellulose (HPMC) K15M, HPMC K100M (i.e.: 1:1, 1:2, 1:3) as release retardants. Glyceryl behenate (Compritol 888 ATO) and Glyceryl palmitostearate (Precirol ATO 5) were used (1:1, 1:2, 1:3) as low-density lipids to impart buoyancy for longer period. The drug (LTD) and excipient (i.e. HPMC, low-density lipid aids, etc.) interaction studies were carried out by Fourier Transform Infrared Spectroscopy (FTIR) and there was no likely interaction involving them. The developed LTD floating matrix tablets were characterized by pre and post-compression parameters and all results were found within the pharmacopoeial limits. The cumulative percentage of drug release ranges from 56.87 ± 0.25% (074_F12) to 99.87 ± 0.09% (074_F2). The drug release profiles of the all formulations (074_F1 to 074_F12) were subjected to various pharmacokinetic parameters and the optimized formulation (074_F3) followed the Korsmeyer Peppas (R²=0.996) model with non-Fickian diffusion (n>0.5). The obtained data by radiographic images of 074_F3 formulation showed the GRT of 6±0.5 h (n=3). Hence, from all evaluation studies, it was evident that 074_F3 formulation was optimized (99.82±1.63 % drug release in 12 h).",
        "introduction": "LTD is a lipophilic, non-sedating H1 blocker used to treat seasonal allergic rhinitis having low bioavailability (40%) and biological half-life (8h). To avoid frequent administration and improve patient compliance, an extended-release floating matrix formulation was planned. Low-density lipids like Compritol and Precirol were used to allow the formulation to stay on top of gastric contents, avoiding first-pass metabolism and improving bioavailability.",
        "materials_and_methods": {
            "materials_origin": {
                "Loratadine": "Hetero Labs Ltd, Hyderabad, India",
                "HPMC K15M and HPMC K100M": "B and K Technologies, China",
                "Compritol 888 ATO (Glyceryl behenate) and Precirol ATO 5 (Glyceryl palmitostearate)": "Gattefosse, Germany",
                "MCC (Avicel PH 200), Aerosil, Magnesium stearate": "SD Fine Chemicals Ltd., Mumbai",
                "Hydrochloric acid": "Merck specialties Pvt. Ltd. Mumbai, India"
            },
            "experimental_design_for_optimization": {
                "method": "Non-effervescent floating matrix tablets were prepared by direct compression.",
                "independent_variables": [
                    "Polymer type and ratio (HPMC K15M, HPMC K100M)",
                    "Lipid type and ratio (Compritol 888 ATO, Precirol ATO 5)"
                ],
                "levels": "Polymer and lipid ratios were taken as 1:1, 1:2, and 1:3 relative to the drug or in combination, as per Table 1."
            },
            "calibration_curve": {
                "solvent": "0.1N HCl",
                "concentration_range": "5 µg/ml to 45 µg/ml",
                "absorbance_wavelength": "280 nm",
                "regression_coefficient_R2": "0.998",
                "equation": "Not specified in the article"
            },
            "ftir_spectral_measurements": {
                "instrument": "FTIR (Star Tech Labs Pvt. Ltd., Hyderabad)",
                "method": "KBr disk method",
                "frequency_range": "4000 - 400 cm⁻¹",
                "resolution": "4 cm⁻¹",
                "result": "No interaction between drug and polymers was found. Principle peaks of the pure drug were present in the optimized formulation (074_F3)."
            },
            "dsc_analysis": {
                "instrument": "Differential scanning calorimeter",
                "sample_size": "5 - 15 mg",
                "temperature_range": "50 - 300°C",
                "heating_rate": "10 °C/min",
                "atmosphere": "Nitrogen",
                "result": "Pure drug showed a sharp endothermic peak at 136.11°C. Optimized formulation (074_F3) showed a sharp endothermic peak at 135.10°C, indicating compatibility."
            },
            "tablet_fabrication_process": {
                "method": "Direct compression",
                "equipment": "10 station rotary tablet punching machine (Karnavathi, Gujarat, India)",
                "tooling": "6 mm circular standard flat-faced punch",
                "compression_weight": "100 mg of lubricated blend per tablet",
                "compression_force_pressure": "Not specified in the article",
                "coating": "No coating applied"
            }
        }
    },
