    "experimental_data": {
        "key_results": [
            "Cedrela gum is a low viscosity polymer (48 cPs) with a hydroxyl group.",
            "Formulations with Cedrela gum showed better flow (angle of repose 24-27°), lower Py and Pk values (more plastic) than HPMC (p<0.05).",
            "Gurnham equation showed limitations for plasto-elastic materials.",
            "Crushing strength at 2% binder: Cedrela gum (130.95 N) > HPMC (117.85 N). Friability <1% for all.",
            "Cedrela gum tablets were non-disintegrating with significantly longer drug release than HPMC.",
            "At 4% binder, Cedrela gum showed highest bioadhesion in pH 6.8 buffer (150.08 min).",
            "No damage to intestinal mucosa observed in histopathological evaluation."
        ],
        "statistical_analysis": "ANOVA and t-test used. p ≤ 0.05 considered significant. Cedrela gum significantly more plastic than HPMC (p<0.05). Crushing strength significantly higher for gum formulations (p<0.05).",
        "in_vitro_studies": [
            "Dissolution (pH 7.4 phosphate buffer)",
            "Bioadhesion (rotating cylinder method on pig ileum in pH 6.8 buffer and 0.1 M HCl)"
        ],
        "histopathology": "Light microscopy of intestinal mucosa before and after adhesion showed no damage."
    }
