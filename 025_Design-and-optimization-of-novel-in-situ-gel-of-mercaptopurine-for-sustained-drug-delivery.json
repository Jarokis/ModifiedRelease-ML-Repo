    "experimental_design_for_optimization": {
        "design_type": "3^2 full factorial design",
        "independent_variables": [
            {
                "variable": "X1",
                "name": "Percentage of xanthan gum",
                "levels": [
                    "30%",
                    "40%",
                    "50%"
                ],
                "coded_values": {
                    "-1": 30,
                    "0": 40,
                    "+1": 50
                }
            },
            {
                "variable": "X2",
                "name": "Percentage of sodium chloride",
                "levels": [
                    "5%",
                    "7.5%",
                    "10%"
                ],
                "coded_values": {
                    "-1": 5,
                    "0": 7.5,
                    "+1": 10
                }
            }
        ],
        "dependent_variables": [
            "Swelling index",
            "Cumulative Percent Release (CPR)"
        ],
        "polymer_selection": {
            "method": "Placebo tablet screening (batches P1-P10)",
            "selected_polymer": "Xanthan gum",
            "selection_criteria": "Best hardness, swelling index, and disintegration time",
            "results_summary": "Xanthan gum tablets (P1, P2) showed highest swelling (90-99%) and hardness (>4.5 kg/cm²). PEG-6000 tablets (P9, P10) showed negligible swelling and low hardness."
        },
        "diluent_selection": {
            "method": "Evaluation of formulations 025_F1, 025_F2, 025_F3",
            "selected_diluent": "Microcrystalline Cellulose (MCC)",
            "basis": "Formulation 025_F1 with MCC alone released drug faster, indicating need for release modifier; 025_F2 (spray dried lactose) and 025_F3 (combination) showed slower release."
        },
        "release_modifier": "Sodium chloride (5%, 7.5%, 10%)",
        "regression_equations": {
            "swelling_index": "Y1 = 839.36 + 159.03X1 - 186.50X2",
            "cpr": "Y2 = 74.835 - 14.887X1 + 10.04X2 - 2.765X1X2 - 7.390X1^2 + 5.781X2^2"
        },
        "absorbance_wavelength": "311 nm",
        "software_used": "PCP Disso 2000 V3, PCP Disso Version 2.08"
    },
