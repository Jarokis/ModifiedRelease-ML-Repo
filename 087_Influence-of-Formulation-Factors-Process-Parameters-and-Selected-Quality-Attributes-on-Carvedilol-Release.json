{
  "article_summary": {
    "title": "Influence of Formulation Factors, Process Parameters, and Selected Quality Attributes on Carvedilol Release from Roller-Compacted Hypromellose-Based Matrix Tablets",
    "authors": [
      "Alea Dular Vovko",
      "Bor Hodzic",
      "Tina Brec",
      "Grega Hudovornik",
      "Franc Vrečer"
    ],
    "journal": "Pharmaceuticals",
    "year": 2022,
    "objective": "To evaluate the combined effects of formulation factors, process parameters, and selected quality attributes on drug release from roller-compacted hypromellose-based matrix tablets containing carvedilol."
  },
  "sections": {
    "abstract": {
      "location": "Page 1",
      "summary": "The study evaluated factors affecting drug release from roller-compacted HPMC matrix tablets with carvedilol. Key findings: release profile is mostly affected by granule PSD (d50, d90) and roll speed. Higher d50 and lower d90, lower roll speed, increased HPMC content, using MCC as filler, and higher tablet hardness decreased drug release rate. Roll pressure, screen aperture size, and d10 had insignificant effects."
    },
    "introduction": {
      "location": "Pages 1-2",
      "summary": "Discusses the benefits of hydrophilic matrix tablets, the use of hypromellose (HPMC), challenges with direct compression, advantages of roller compaction over wet granulation, and prior studies on roller compaction for HPMC tablets. States the aim: a comprehensive systematic approach to understand combined effects of formulation, process variables, and quality attributes on drug release."
    },
    "materials_and_methods": {
      "location": "Pages 2-5",
      "summary": "Describes raw materials, tablet composition, preparation of compression mixture and tableting, and various analytical methods (SFT for PSD, tablet testing, drug release testing, statistical analysis, laser diffraction, dynamic image analysis, density measurements, compressibility/compactibility studies)."
    },
    "results_and_discussion": {
      "location": "Pages 5-12",
      "summary": "Presents statistical analysis results, effects of various factors on drug release, detailed discussion on PSD effects, compressibility/compactibility studies, and the influence of roll speed and filler type. Explains the contradictory effects of d50 and d90 on release rate."
    },
    "conclusions": {
      "location": "Pages 12-13",
      "summary": "Drug release rate is affected by a combination of factors. Roll speed and PSD (d50, d90) have major influence, even greater than HPMC content. Lower d90 and higher d50 (via fragmentation) lead to slower release. SFT is a promising tool for monitoring and control. Predictive models need testing on larger scale."
    }
  },
  "materials_origin": {
    "carvedilol": "Krka, d.d., Novo mesto, Slovenia",
    "hypromellose": "METHOCEL™ K4M Premium CR grade, Colorcon, Dow Chemical Co., Midland, MI, USA",
    "lactose_monohydrate": "Lactose monohydrate 200 mesh, DFE Pharma, Goch, Germany",
    "microcrystalline_cellulose": "CEOLUS™ KG802, Asahi Kasei Corporation, Tokyo, Japan",
    "magnesium_stearate": "Faci SpA, Carasco, Italy",
    "colloidal_silicon_dioxide": "AEROSIL® 200 Pharma, Evonik Degussa GmbH, Essen, Germany"
  },
  "experimental_design": {
    "independent_variables": [
      "hypromellose content (25%, 35%, 45%)",
      "filler type (lactose monohydrate, MCC)",
      "roll speed (3, 5, 7 rpm)",
      "roll pressure (30, 70, 110 bar)",
      "screen aperture size (0.80, 1.00, 1.25 mm)",
      "PSD of granules (d10, d50, d90)",
      "tablet hardness (80 N, 100 N)"
    ],
    "dependent_variables": "Drug release at 1, 2, 3, 4, 5, 6, 7, 8 hours",
    "statistical_method": "Multi-way analysis of variance (ANOVA), reduced linear predictive models using Unscrambler and Design-Expert",
