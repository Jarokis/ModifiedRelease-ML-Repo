    "experimental_design_for_optimization": {
        "software": "Design-Expert 10.1.1 (Stat-Ease Inc., Minneapolis, MN)",
        "design_type": "Response Surface Methodology (I-Optimal design)",
        "independent_variables": [
            {
                "variable": "A: Amount of super-disintegrant (CCS)",
                "low_level": 15,
                "high_level": 30,
                "unit": "mg"
            },
            {
                "variable": "B: Avicel: Mannitol (A:M) ratio",
                "levels": [
                    "2.5:5",
                    "5:2.5",
                    "7.5:0",
                    "5:0"
                ],
                "unit": "ratio"
            }
        ],
        "dependent_responses": [
            {
                "response": "R1: Disintegration time",
                "aim": "Minimize",
                "unit": "min"
            },
            {
                "response": "R2: Percentage of drug released after 24 h",
                "aim": "Maximize",
                "unit": "%"
            }
        ],
        "model_equation_r1": "R1 = +9.35 – 3.85*A + 0.93*B1 – 2.22*B2 – 2.97*B3 – 1.25*AB1 + 1.93*AB2 + 0.85*AB3",
        "model_equation_r2": "R2 = +94.44 + 2.58*A – 1.72*B1 – 0.32*B2 + 2.41*B3 + 1.19*AB1 + 0.92*AB2 – 0.53*AB3",
        "model_fit_r1": "2FI, R²=0.9995, Adjusted R²=0.9989",
        "model_fit_r2": "2FI, R²=0.9628, Adjusted R²=0.9107",
        "optimized_composition": {
            "ccs_amount_mg": 30,
            "avicel_mannitol_ratio": "7.5:0",
            "desirability": 0.967
        }
