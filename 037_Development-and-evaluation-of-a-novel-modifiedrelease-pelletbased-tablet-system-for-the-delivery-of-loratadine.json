    "experimental_design": {
        "preparation_methods": {
            "immediate_release_pellets": "Extrusion-spheronization method. Wet mass prepared in planetary mixer (160 rpm, 10 min), extruded at 1000 rpm (rotary gear extruder, Caleva model 40, 1.00 mm die), spheronized at 1000 rpm for 10 min (Caleva model 380), dried in fluidized bed dryer (Burkard, FBD 350S) at 60°C for 30 min.",
            "prolonged_release_coated_pellets": "Fluidized bed coating (Aromatic-Fielder AG, Switzerland) with Wurster insert. Inner HPMC coat (2.5% w/w), outer Kollicoat SR-30D coat (15%, 17.5%, 20% w/w), and final HPMC overcoat (1% w/w).",
            "multiple_unit_capsules": "Manual filling of 037_F1 (150 mg) and 037_F4 (185 mg) pellets into size '0' hard gelatin capsules.",
            "multiple_unit_tablets": "Compression of 037_F1 pellets (150 mg), 037_F4 pellets (185 mg), and inert Ceolus KG-801 granules (150 mg) using single punch tableting machine (Manesty, England) with 10 mm flat-faced punches."
        },
        "equations": {
            "yield": "Yield(%) = (Weight of pellets / Weight of powder ingredients fed initially) × 100%",
            "geometric_mean_diameter": "Method from Schaefer & Worts (1977) [Reference 14]"
        },
        "absorbance_wavelengths": {
            "pseudoephedrine_hcl_uv": "215 nm",
            "hplc_detection": "265 nm"
        }
    },
