    "experimental_design_for_optimization": {
        "description": "Six sustained-release matrix tablet formulations (124_F1–124_F6) were prepared using wet granulation, varying type and concentration of hydrophilic polymers (HPMC E-15, Carbopol 934, Sodium CMC) and lactose filler to study their effect on rabeprazole release over 10 h.",
        "design_type": "Simple comparative formulation study (no formal factorial/RSM optimization reported).",
        "batches": [
            "124_F1",
            "124_F2",
            "124_F3",
            "124_F4",
            "124_F5",
            "124_F6"
        ],
        "independent_variables": [
            "Polymer type: HPMC E-15, Carbopol 934, Sodium CMC",
            "Polymer concentration per tablet (mg)",
            "Presence/amount of lactose diluent"
        ],
        "dependent_variables": [
            "Cumulative drug release over 10 h",
            "Tablet hardness",
            "Flow properties (angle of repose, densities, Carr's index)",
            "Drug content uniformity"
        ],
        "optimization_note": "No statistical optimization (e.g., design of experiments, regression models) is described; conclusions are based on comparative release profiles and qualitative assessment."
    },
