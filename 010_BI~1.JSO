      "PK_parameters_mean_SD": {
        "metformin_test": { "Cmax_ng_per_mL": "707.3 ± 114.7", "Tmax_h": "5.2 ± 1.5", "t_half_h": "5.76 ± 1.62", "AUC0_t_h_ng_per_mL": "6137.4 ± 816.1", "AUC0_inf_h_ng_per_mL": "6225.5 ± 825.1" },
        "metformin_reference": { "Cmax_ng_per_mL": "741.1 ± 124.0", "Tmax_h": "5.4 ± 1.5", "t_half_h": "5.53 ± 1.04", "AUC0_t_h_ng_per_mL": "6951.2 ± 1632.1", "AUC0_inf_h_ng_per_mL": "7020.2 ± 1646.0" },
