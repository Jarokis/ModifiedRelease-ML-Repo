{
  "article_metadata": {
    "title": "Bilayer tablets with sustained‑release metformin and immediate‑release sitagliptin: preparation and in vitro/in vivo evaluation",
    "journal": "Journal of Pharmaceutical Investigation",
    "year": 2021,
    "doi": "10.1007/s40005-021-00533-z",
    "authors": [
      "Ngoc Nha Thao Nguyen",
      "Duy Toan Pham",
      "Duc Tuan Nguyen",
      "Thi Thu Loan Trinh"
    ],
    "reference_product": "Janumet XR 50/500 mg",
    "source": "[attached_file:1]"
  },
  "section_index": {
    "abstract": "Purpose, methods overview, headline in vitro/in vivo results, conclusion [attached_file:1]",
    "introduction": "Clinical context, rationale, limitations of coating, prior reports [attached_file:1]",
    "materials_and_methods": "Materials origin, preparation of each layer, bilayer compression, dissolution/HPLC, LC–MS/MS, DoE [attached_file:1]",
    "results_and_discussion": "Optimization (DoE), tablet quality, stability, release profiles and f2, excipient effects [attached_file:1]",
    "conclusion": "Performance summary and bioequivalence statement [attached_file:1]"
  },
  "materials_origin": {
    "metformin_hydrochloride": "Vistin Pharma Co., Ltd. (Norway) [attached_file:1]",
    "sitagliptin_phosphate_monohydrate": "Harman Co., Ltd. (India) [attached_file:1]",
    "standards": {
      "metformin_standard": "Institute of Drug Quality Control Ho Chi Minh City (92.20%) [attached_file:1]",
      "phenformin_internal_standard": "Institute of Drug Quality Control Ho Chi Minh City (95.00%) [attached_file:1]",
      "sitagliptin_standard": "Sigma Aldrich (USA, 95.00%) [attached_file:1]"
    },
    "excipients": {
      "HPMC_K100M": "Dow Chemical Co. (USA) [attached_file:1]",
      "magnesium_stearate": "Mingtai Co., Ltd. (Taiwan) [attached_file:1]",
      "microcrystalline_cellulose_Avicel_PH_101": "Mingtai Co., Ltd. (Taiwan) [attached_file:1]",
      "PVP_K30_and_K90": "ISP, Ltd. (USA) [attached_file:1]"
    },
    "grades": "Other excipients ≥ analytical grade; HPLC solvents chromatographic grade [attached_file:1]"
  },
  "experimental_design_for_optimization": {
    "design": "D-optimal design (Design-Expert, Stat-Ease) [attached_file:1]",
    "independent_variables": [
      { "name": "HPMC K100M (amount)", "levels": ["-1","0","1"], "type": "numeric [attached_file:1]" },
      { "name": "Carbopol (amount)", "levels": ["-1","0","1"], "type": "numeric [attached_file:1]" },
      { "name": "Water amount in wet granulation", "levels": ["-1","1"], "type": "numeric [attached_file:1]" }
    ],
    "responses": [
      "% MH released at 1 h",
      "% MH released at 2 h",
      "% MH released at 6 h",
      "% MH released at 10 h"
    ],
    "runs": 14,
    "selection_criterion": "Similarity to Janumet XR dissolution (f2 > 50) and acceptable tablet properties [attached_file:1]"
  },
  "ingredients_identification": {
    "dissolution_assay_detection": {
      "technique": "HPLC-UV at 265 nm (Hitachi L-2000) [attached_file:1]",
      "column": "Phenomenex Luna RP-C8, 4.6×250 mm, 5 µm [attached_file:1]",
      "mobile_phase": "5 mM sodium laureth sulfate with 0.1% triethylamine (pH 4.0 with phosphoric acid):methanol 30:70 v/v [attached_file:1]",
      "flow_rate_mL_per_min": 1.0
    },
    "bioanalytical_quantification": {
      "technique": "LC–MS/MS (Triple Quadrupole Xevo, ESI+), MRM [attached_file:1]",
      "column": "Gemini C18, 250×4 mm, 5 µm [attached_file:1]",
      "mobile_phase": "0.1% formic acid:methanol 45:55 v/v, 1.0 mL/min, 10 µL injection [attached_file:1]",
      "ion_transitions_mz": {
        "metformin": "130 → 71 [attached_file:1]",
        "sitagliptin": "408 → 235 [attached_file:1]",
        "phenformin_IS": "206 → 105 [attached_file:1]"
      },
      "calibration": {
        "metformin": "y = 0.01175x − 0.05701, R^2 = 0.9987, range 5–3200 ng/mL [attached_file:1]",
        "sitagliptin": "y = 0.23278x − 0.00077, R^2 = 0.9968, range 1–799 ng/mL [attached_file:1]"
      },
      "source": "[attached_file:1]"
    },
    "similarity_factor_equation_LaTeX": "\\[ f_2 = 50 \\times \\log\\left\\{\\left(1 + \\frac{1}{n} \\sum_{t=1}^{n} (R_t - T_t)^2 \\right)^{-0.5} \\times 100\\right\\} \\]",
    "notes": "Absorbance per se not reported; quantification based on HPLC-UV area and LC–MS/MS MRM [attached_file:1]"
  },
  "formulation_details_per_layer_optimal_batch": {
    "metformin_layer_sustained_release": {
      "ingredients_mg_per_tablet": [
        { "name": "Metformin HCl", "amount_mg": 500.00 },
        { "name": "HPMC K100M", "amount_mg": 246.00 },
        { "name": "Carbopol", "amount_mg": 81.00 },
        { "name": "PVP K30", "amount_mg": 60.00 },
        { "name": "Magnesium stearate", "amount_mg": 10.00 },
        { "name": "Aerosil (fumed silica)", "amount_mg": 5.00 },
        { "name": "Avicel PH-101", "amount_mg": 68.00 }
      ],
      "layer_total_mass_mg": 970.00,
      "source": "[attached_file:1]"
    },
    "sitagliptin_layer_immediate_release": {
      "ingredients_mg_per_tablet": [
        { "name": "Sitagliptin (equivalent)", "amount_mg": 50.00 },
        { "name": "Ludipress", "amount_mg": 50.00 },
        { "name": "Sodium starch glycolate", "amount_mg": 15.00 },
        { "name": "PVP K90", "amount_mg": 30.00 },
        { "name": "Magnesium stearate", "amount_mg": 2.50 },
        { "name": "Aerosil (fumed silica)", "amount_mg": 0.50 },
        { "name": "A-tab", "amount_mg": 137.75 }
      ],
      "layer_total_mass_mg": 285.75,
      "source": "[attached_file:1]"
    },
    "bilayer_total_mass_mg": 1255.75,
    "notes": "Table 1 lists only the optimal composition; other DoE trial compositions are in Supplementary Data [attached_file:1]"
  },
