  "process_parameters": {
    "wet_granulation_metformin_layer": {
      "sieving": "0.3 mm pre-sieve of powders; wet mass pressed through 0.8 mm screen [attached_file:1]",
      "binder_solution": "10% w/w PVP K30 in 70% ethanol [attached_file:1]",
      "drying": "60 °C for 6 h [attached_file:1]",
      "post_dry_blend": "Sieving 0.8 mm, then blend with carbopol, magnesium stearate, Aerosil [attached_file:1]"
    },
    "direct_compression_sitagliptin_layer": {
      "sieving": "SG and sodium starch glycolate through 0.3 mm [attached_file:1]",
      "blending": "With Ludipress, A‑tab, PVP K90 in cube mixer; add magnesium stearate and Aerosil [attached_file:1]"
    },
    "bilayer_compression": {
      "machine": "2‑layer tablet press (N.R.Narongkarnchang, Thailand) [attached_file:1]",
      "die": "Caplet L 19 mm × W 11 mm [attached_file:1]",
      "first_compression": "Metformin layer to intermediate tablet at 7 ± 2 kg/cm² [attached_file:1]",
      "final_compression": "Add SG layer and compress at 18 ± 3 kg/cm² [attached_file:1]",
      "coating": "None (bilayer avoids SG coating) [attached_file:1]"
    },
    "dissolution_test": {
      "apparatus": "USP Apparatus I (basket), Pharmatest [attached_file:1]",
      "media": ["pH 1.2 HCl", "pH 4.5 phosphate buffer", "pH 6.8 phosphate buffer"],
      "volume_mL": 1000,
      "rotation_rpm": 100,
      "temperature_C": "37 ± 0.5",
      "sampling_times": {
        "sitagliptin": ["5 min", "15 min", "30 min"],
        "metformin": ["1 h", "2 h", "6 h", "10 h"]
      },
      "filtration": "0.45 µm membrane [attached_file:1]",
      "HPLC_detection": "UV 265 nm with conditions as above [attached_file:1]"
    },
    "bioanalytical_LC_MS_MS": {
      "instrument": "Triple Quadrupole Mass Spectrometer Xevo (ESI+, MRM) [attached_file:1]",
      "key_settings": {
        "interface_voltage_V": 40,
        "desolvation_line_temperature_C": 500,
        "nebulizer_gas_flow_L_per_h": 1000,
        "dwell_time_s": 0.02,
        "collision_voltage_eV": { "MH": 20, "SG": 18, "phenformin": 18 }
      },
      "pharmacokinetic_software": "WinNonlin Equiv Test PK (Certara) [attached_file:1]"
    }
  },
  "release_properties": {
    "sitagliptin_immediate_release": {
      "design_goal": ">95% within 30 min (pH 1.2) achieved [attached_file:1]",
      "release_percent_mean_SD": {
        "pH_1_2": {
          "5_min": { "test": "15.06 ± 7.32", "reference": "14.26 ± 5.46" },
          "15_min": { "test": "59.39 ± 4.09", "reference": "68.58 ± 2.58" },
          "30_min": { "test": "98.86 ± 6.21", "reference": "99.36 ± 3.21" }
        },
        "pH_4_5": {
          "5_min": { "test": "16.22 ± 4.13", "reference": "14.00 ± 3.41" },
          "15_min": { "test": "58.84 ± 3.54", "reference": "67.43 ± 3.86" },
          "30_min": { "test": "99.74 ± 0.85", "reference": "99.02 ± 2.11" }
        },
        "pH_6_8": {
          "5_min": { "test": "17.09 ± 4.44", "reference": "12.82 ± 6.13" },
          "15_min": { "test": "54.56 ± 4.09", "reference": "63.57 ± 5.59" },
          "30_min": { "test": "98.11 ± 2.84", "reference": "94.32 ± 3.44" }
        }
      },
      "f2_similarity": { "pH_1_2": 63.30, "pH_4_5": 64.05, "pH_6_8": 60.26 },
      "kinetics_modeling": "Not modeled (no zero/first-order/Korsmeyer–Peppas fits reported) [attached_file:1]"
    },
    "metformin_sustained_release": {
      "design_goal": "Sustain release ~10 h (pH 6.8) achieved [attached_file:1]",
      "release_percent_mean_SD": {
        "pH_1_2": {
          "1_h": { "test": "32.19 ± 6.37", "reference": "30.53 ± 9.11" },
          "2_h": { "test": "48.12 ± 2.23", "reference": "50.34 ± 6.26" },
          "6_h": { "test": "78.84 ± 3.49", "reference": "86.38 ± 5.25" },
          "10_h": { "test": "97.14 ± 2.83", "reference": "100.27 ± 4.37" }
        },
        "pH_4_5": {
          "1_h": { "test": "32.26 ± 3.28", "reference": "28.02 ± 5.11" },
          "2_h": { "test": "47.53 ± 1.85", "reference": "47.71 ± 5.20" },
          "6_h": { "test": "80.77 ± 4.85", "reference": "85.02 ± 4.46" },
          "10_h": { "test": "99.42 ± 3.87", "reference": "102.99 ± 2.41" }
        },
        "pH_6_8": {
          "1_h": { "test": "31.43 ± 6.48", "reference": "28.51 ± 7.48" },
          "2_h": { "test": "47.93 ± 7.55", "reference": "46.59 ± 5.91" },
          "6_h": { "test": "80.75 ± 5.32", "reference": "81.63 ± 6.61" },
          "10_h": { "test": "97.27 ± 1.72", "reference": "99.20 ± 2.95" }
        }
      },
      "f2_similarity": { "pH_1_2": 67.50, "pH_4_5": 71.95, "pH_6_8": 83.19 },
      "mechanistic_factors": "HPMC K100M slight pre-swelling via limited water in granulation traps MH; carbopol forms outer gel retarding early release [attached_file:1]"
    },
    "excipient_effects_at_pH_6_8": {
      "without_carbopol": {
        "1_h": "43.25 ± 4.37",
        "2_h": "56.19 ± 3.23",
        "6_h": "81.04 ± 6.82",
        "10_h": "98.30 ± 2.15"
      },
      "with_carbopol": {
        "1_h": "31.43 ± 6.48",
        "2_h": "47.93 ± 7.55",
        "6_h": "80.75 ± 5.32",
        "10_h": "97.27 ± 1.72"
      },
      "interpretation": "Carbopol further sustains MH release, notably at 1–2 h [attached_file:1]"
    }
  },
