        "sitagliptin_test": { "Cmax_ng_per_mL": "216.3 ± 52.1", "Tmax_h": "2.9 ± 1.2", "t_half_h": "8.71 ± 1.96", "AUC0_t_h_ng_per_mL": "1885.3 ± 226.8", "AUC0_inf_h_ng_per_mL": "1920.0 ± 234.1" },
        "sitagliptin_reference": { "Cmax_ng_per_mL": "200.7 ± 46.6", "Tmax_h": "3.5 ± 1.7", "t_half_h": "8.63 ± 1.85", "AUC0_t_h_ng_per_mL": "1857.4 ± 307.9", "AUC0_inf_h_ng_per_mL": "1888.3 ± 311.9" },
        "sitagliptin_T_over_R_percent": { "Cmax": 107.77, "Tmax": 82.86, "t_half": 100.93, "AUC0_t": 101.50, "AUC0_inf": 101.68 }
      },
      "bioequivalence_criterion": "T/R ratios within 80–120% satisfied [attached_file:1]"
    },
    "statistics": {
      "methods": ["One-way ANOVA", "Student’s t-test", "Wilcoxon test for Tmax"],
      "significance_threshold": "p < 0.05 [attached_file:1]"
