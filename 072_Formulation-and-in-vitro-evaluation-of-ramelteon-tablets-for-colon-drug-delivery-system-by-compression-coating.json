{
    "article_info": {
        "title": "FORMULATION AND IN VITRO EVALUATION OF RAMLETON TABLETS FOR COLON DRUG DELIVERY SYSTEM BY COMPRESSION COATING",
        "authors": "TRINADHA RAO M., PARIMALA Y., YAMINI M., PHANINDRA CVS, SRINIVASA RAO Y.",
        "journal": "International Journal of Applied Pharmaceutics",
        "year": 2021,
        "doi": "https://dx.doi.org/10.22159/ijap.2021v13i2.40396"
    },
    "materials_origin": {
        "ramleton": "Gift sample from Dr. Reddy's Laboratories, Hyderabad, Andhra Pradesh, India",
        "excipients": "Cross carmellose sodium, Microcrystalline cellulose (MCC pH 102), Talc, Magnesium stearate, Ethyl cellulose, Eudragit RLP0, Eudragit L100 – sources not specified"
    },
    "experimental_design": {
        "approach": "Compression coating technology. Core tablets containing drug and superdisintegrant were prepared, then compression coated with pH‑dependent polymers (ethylcellulose, Eudragit RLP0, Eudragit L100).",
        "batches": "Nine formulations (072_F1–072_F9) with varying polymer compositions in the coating layer.",
        "optimization": "072_F4 identified as optimized based on drug release retardation up to 18 h (99.25% release)."
    },
    "ingredients_identification": {
        "preparation": "Core tablets prepared by direct compression; coating layer applied by compression coating using 9 mm flat punch. Pre‑compression blends tested for flow properties (all passed).",
        "results": "FTIR showed no interaction between drug and excipients.",
        "equation": "Release kinetics evaluated using zero‑order, first‑order, Higuchi, and Korsmeyer‑Peppas models.",
        "absorbance": "UV‑Vis analysis at 254 nm (pH 1.2), 256 nm (pH 7.4), and 257 nm (pH 6.8). Calibration curves linear (r² > 0.99)."
    },
