    "fourier_transform_infrared_spectral_measurements": {
        "method": "KBr pellet method; 3 mg sample + 300 mg KBr compressed at 10 kg/cm to form pellet; scanned 4000–500 cm^-1 using FT-IR Affinity-1 (Shimadzu).",
        "findings": {
            "EtM_key_peaks_cm_minus1": [
                3452.82,
                3118.51,
                2912.14
            ],
            "optimum_formulations_tested": [
                "015_F9 (ODT)",
                "015_F10 (ODT)",
                "015_S6 (SR)"
            ],
            "compatibility_conclusion": "All peaks of the optimum formulae (015_F9, 015_F10 and 015_S6) exist in their original position without shifting — indicating no incompatibility between EtM and excipients in the tested formulas.",
            "note": "FT-IR spectra for 015_S6 (SR) and 015_F9/015_F10 (ODTs) are included in the article's figures; the article reports absence of drug–excipient interactions based on the preserved characteristic peaks."
        }
    },
