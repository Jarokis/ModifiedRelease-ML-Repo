    "release_properties": {
        "SR_tablet_testing_conditions": {
            "two_stage_dissolution": "0–2 h in 900 mL 0.1 N HCl (pH 1.2), then transfer to phosphate buffer pH 6.8 (900 mL) for the remainder (up to 24 h).",
            "apparatus": "USP dissolution apparatus (not further numerically specified in Methods beyond apparatus type); paddle",
            "temperature_C": 37,
            "sampling": "5 mL aliquots withdrawn at predetermined intervals and replaced with fresh medium; samples filtered (0.22 µm) and assayed spectrophotometrically at λmax=284 nm."
        },
        "S1_to_S9_release_summary": {
            "general_findings": "Formulations compressed with either HPMC or MC or EC showed extended release for up to 24 h; type and concentration of matrix-forming polymer affected release (higher polymer concentration decreased release).",
            "S6_specific": {
                "release_at_24h_percent": 70.48,
                "release_at_24h_SD": 0.08,
                "article_statement": "015_S6 shows more hindering of the drug release (70.48 ± 0.08%) after 24 h and therefore was selected as the sustained core formula."
            },
            "full_timepoint_release_profiles": {
                "data_not_provided_in_article": true,
                "explanation": "The article provides release curves (figures) but does not tabulate the full numeric time-by-time dissolution data in the text or tables; only the summary 24-h value for 015_S6 is numerically given explicitly."
            }
        },
        "release_mechanism_discussion": {
