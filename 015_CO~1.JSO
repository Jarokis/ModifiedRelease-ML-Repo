{
    "source": {
        "article_title": "Core in Cup Ethylmorphine Hydrochloride Tablet for Dual Fast and Sustained Pain Relief: Formulation, Characterization, and Pharmacokinetic Study",
        "authors": [
            "Aliaa Nabil ElMeshad",
            "Khaled M. Abdel-Haleem",
            "Nabaweya A. Abdel Gawad",
            "Mohamed Ahmed El-Nabarawi",
            "Nermin M. Sheta"
        ],
        "journal": "AAPS PharmSciTech",
        "year": 2020,
        "file_citation": ":contentReference[oaicite:1]{index=1}"
    },
    "materials_origin": {
        "Ethylmorphine_hydrochloride": "gift sample from Macfarlan Smith Ltd., Edinburgh (UK).",
        "Mannitol_SD_USP_grade": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Glycine": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Gelatin": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Alpha_lactose_monohydrate_350M": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Potassium_dihydrogen_phosphate": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Disodium_hydrogen_phosphate": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Potassium_chloride": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Hydrochloric_acid": "El-Nasr Pharmaceutical Chemicals Co., Egypt.",
        "Maltodextrin_Maltrin_QDTM_M500": "Sigma-Aldrich Co., Steinheim, Germany.",
        "Ethyl_cellulose_Ethocel_Premium": "Sigma-Aldrich Co., Steinheim, Germany.",
        "Hydroxypropyl_methylcellulose_K4M": "Sigma-Aldrich Co., Steinheim, Germany.",
        "Magnesium_stearate_LR": "SD Fine-Chem Limited, Mumbai, India.",
        "Methyl_cellulose": "Dow Chemical Company, Midland, MI, USA.",
        "MST_containing_morphine_sulfate (marketed comparitor)": "Medical Union Pharmaceuticals (MUP).",
        "Orthophosphoric_acid_and_acetonitrile_HPLC_grade": "Merck, Germany."
    },
    "experimental_design_for_optimization": {
        "ODT_cup_design": {
            "design_type": "4^1 · 2^2 full factorial (Design-Expert software)",
            "independent_variables": {
                "X1_binder_concentration": [
                    "20%",
                    "30%",
                    "40%",
                    "50%"
                ],
                "X2_binder_type": [
                    "gelatin",
                    "methyl cellulose (MC)"
                ],
                "X3_filler_type": [
                    "mannitol (MAN)",
                    "maltodextrin (MDX)"
                ]
            },
            "dependent_variables": {
                "Y1": "disintegration time (DT) — minimize",
                "Y2": "drug release (%) — maximize"
            }
        },
        "SR_core_design": {
            "design_type": "3^2 full factorial",
            "independent_variables": {
                "X1_binder_type": [
                    "methyl cellulose (MC)",
                    "ethyl cellulose (EC)",
                    "hydroxypropyl methylcellulose (HPMC)"
                ],
                "X2_binder_concentration": [
                    "20%",
                    "30%",
                    "40%"
                ]
            },
            "dependent_variable": {
                "Y1": "drug release (%) — minimize (i.e., sustained release)"
            }
        },
        "selection_criteria": "From ODT factorial results, two formulas (015_F9 & 015_F10) selected as cup (fast IR). From SR factorial 015_S6 selected as sustained core based on in vitro release profile. These choices are stated in the article."
    },
    "ingredients_identification_and_preparation_methods": {
        "general_preparation_methods": {
            "ODT_lyophilization": {
                "binder_hydration": "Gelatin or methyl cellulose dispersed in 0.2 mL distilled water for 30 min then 2 mL added; heated to 40°C until clear.",
                "add_excipients": "Mannitol or maltodextrin and glycine (20 mg) added and dissolved; EtM added; aliquots of 2 mL placed into blister pockets (2 cm diameter), frozen at -20°C for 24 h.",
                "lyophilizer": "Christ Alpha 1-2LD plus (Munich, Germany). Condenser temp -55°C, vacuum 7.6 Pa. Primary drying 12 h at -30°C and 0.37 mbar; secondary drying 12 h at 20°C and 0.01 mbar."
            },
            "SR_direct_compression": {
                "equipment": "Single punch tablet machine (Shakti Pharmatech, Model SSTP-12, India) with flat-faced 8-mm punch/die.",
                "procedure": "Powder components fed manually into die and compressed with constant compression force; each tablet final weight 150 mg containing 40 mg EtM (for SR formulas as composed)."
            }
        },
        "ingredients_identification_notes": {
            "ETM_abbreviation": "EtM = Ethylmorphine hydrochloride",
            "MAN": "Mannitol",
            "MDX": "Maltodextrin",
            "MC": "Methyl cellulose",
            "EC": "Ethyl cellulose",
            "HPMC": "Hydroxypropyl methylcellulose",
            "Mg_ste": "Magnesium stearate",
            "KCl": "Potassium chloride",
            "Lactose": "Alpha-lactose monohydrate 350 M",
            "glycine": "collapse protectant (20 mg in ODT formulas)"
        },
        "analytical_identification": {
            "UV_spectrophotometry": {
                "λ_max_nm": 284,
                "use_case": "Drug content assay for tablets (dissolved in phosphate buffer pH 6.8)."
            },
            "HPLC_for_in_vivo_samples": {
                "column": "ProntoSIL RP-C18 (150 x 4.6 mm), 5 µm",
                "mobile_phase": "water (pH 5.4 with orthophosphoric acid) : acetonitrile 40:60 v/v",
                "flow_rate_mL_min": 1,
                "retention_time_min": 4.2,
                "instrument": "Shimadzu LC-10ADvp with SPD-20A UV/VIS detector"
            }
        }
    },
