        "drug_loading": {
            "equipment": "Conventional coating pan",
            "conditions": {
                "bed_temperature": "~45°C",
                "compressed_air_pressure": "1.0 - 2.0 kg/cm2",
                "peristaltic_pump_speed": "10 - 40 rpm",
                "gun_distance": "15 - 20 cm from pellet bed"
            }
        },
        "drying": {
            "equipment": "Tray drier",
            "conditions": {
                "inlet_temperature": "50±5°C",
                "bed_temperature": "40 - 45°C"
            }
        },
        "coating": {
            "equipment": "Fluidised Bed Coater (FBC) with bottom spray Wurster",
            "conditions": {
                "inlet_temperature": "45 - 50°C",
                "bed_temperature": "40 - 45°C",
                "application_rate": "1 - 3 mL/min",
                "atomizing_air_pressure": "0.8 - 1 Kg/cm2"
            }
        },
        "compression": {
            "equipment": "8 station tablet compression machine (Karnavati Mini Press II)",
            "conditions": "Direct compression method. Blend mixed in Double cone blender for 2-4 minutes."
        }
    },
