{
  "article_summary": {
    "title": "Design and Development of Atenolol Matrix Tablet Employing Natural and Synthetic Polymers",
    "authors": "Adity Bhowmik, Rajia Sultana Nijhu, Tajnin Ahmed, Sharmin Sultana",
    "year": 2013,
    "objective": "Develop sustained release matrix tablets of Atenolol using natural and synthetic polymers for once-daily administration.",
    "key_findings": "Formulations containing eudragit+ethyl cellulose (E-2) and gum acacia (GA-1) showed best sustained release over 8 hours. Starch alone caused rapid release."
  },
