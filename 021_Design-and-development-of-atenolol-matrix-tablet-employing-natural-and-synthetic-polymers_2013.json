      "standard_curve": "Prepared but no equation provided in text"
    }
  },
  "process_parameters": {
    "compression_device": "KBR Compress Machine",
    "punch_size": "10.0 mm round biconvex",
    "compression_pressure": "Not specified",
    "coating": "None",
    "blending": "Polymers and drug sieved through #18, blended 20 min; then lactose, Avicel, SSG added and blended 10 min; then Aerosil-200 and Mg-stearate (#40) blended 3 min",
    "dissolution_conditions": {
      "apparatus": "USP-22 paddle type (Pharmatest DT70)",
      "rpm": 50,
      "temperature": "37 ± 0.5 °C",
      "media": "0.1N HCl for first 2 hours, then phosphate buffer pH 7.4 for next 6 hours",
      "volume": "900 mL",
      "sampling": "10 mL withdrawn at intervals, replaced with fresh medium",
      "analysis": "UV spectrophotometer at 275 nm"
    }
  },
  "ftir": {
