    "experimental_design": {
        "objective": "Investigate influence of polymer level (20%, 30%, 40%) and type (HCO, E-078_RS100, E-078_L100) and filler type (mannitol, Emcompress, dibasic calcium phosphate anhydrous) on release rate and mechanism of baclofen from matrix tablets.",
        "formulation_groups": {
            "rs_series": "E-078_RS100 (pH‑independent), wet granulation, fillers: mannitol (RS‑1 to RS‑3) or Emcompress (RS‑4 to RS‑6)",
            "l_series": "E-078_L100 (pH‑dependent), wet granulation, fillers: mannitol (L‑1 to L‑3) or Emcompress (L‑4 to L‑6)",
            "h_series": "HCO (wax), hot‑melt granulation, fillers: mannitol (H‑1 to H‑3) or anhydrous dibasic calcium phosphate (H‑4 to H‑6)"
        }
    },
    "ingredients_identification": {
        "preparation_method": "Wet granulation: stock ethanolic solutions (50% w/v) of E-078_RS100 or E-078_L100 used as granulating fluid. Hot‑melt granulation: HCO and filler heated to 80‑90°C, drug dispersed, cooled, pulverized.",
        "drug_content_analysis": "First‑derivative spectrophotometry at 226.5 nm (peak height method).",
        "equation": "First‑derivative absorbance measured at 226.5 nm; calibration curve used for quantification.",
        "absorbance": "Not explicitly given; method validated with CV < 1.5%."
    },
