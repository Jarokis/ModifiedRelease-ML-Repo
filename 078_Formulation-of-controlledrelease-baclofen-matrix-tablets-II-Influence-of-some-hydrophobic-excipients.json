    "tablet_properties": {
        "hardness_kg_range": "3.22–15.55",
        "friability_percent_range": "0.15–1.65 (HCO‑based tablets higher, up to 1.65)",
        "disintegration_time": "Not measured (matrix tablets designed for sustained release)",
        "dissolution_profile_summary": "Release profiles showed pH‑dependency (slower in pH 6.8 due to lower baclofen solubility). Higher polymer content decreased release rate; soluble filler (mannitol) increased release; HCO provided strongest retardation. Release kinetics followed Higuchi model and Korsmeyer‑Peppas equation.",
        "stability": "No significant change in release rate after 6 months storage at ambient room conditions.",
        "thickness_mm_range": "1.66–2.52",
        "weight_variation_percent": "Mean weight within ±5% of label claim"
    },
    "experimental_data": {
        "key_results": "Release rate decreased with increasing polymer content; HCO matrices showed strongest retardation; Emcompress (alkaline filler) enhanced release from E‑078_L100 tablets due to pH‑dependent solubility; mannitol increased release by creating pores; wax matrices (HCO) exhibited Fickian diffusion; some E‑078_RS100 and E‑078_L100 tablets showed anomalous transport.",
        "performance_metrics": "MDT values increased with polymer loading; HCO matrices had significantly higher MDT (p < 0.0001) than E‑078_RS100/E‑078_L100 tablets.",
        "statistical_analysis": "One‑way ANOVA and unpaired t‑test at 5% significance level used; significant differences (p < 0.001) in release rates among polymer levels and types.",
        "release_kinetics_modeling": "Higuchi equation best fit (r² > 0.98); Korsmeyer‑Peppas used to determine release exponent n.",
        "zero_first_order": "Not reported; Higuchi and Korsmeyer‑Peppas were the primary models.",
        "swelling_water_uptake": "Not studied."
    },
