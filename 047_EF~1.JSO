  "release_properties": {
    "common_conditions": {
      "apparatus": "USP release testing apparatus I (Prolabo Dissolutet, France)",
      "volume_ml": 900,
      "temperature_C": 37,
      "rotation_rpm": 50,
      "sampling": "5 ml withdrawn and replaced, assayed by UV at 218 nm"
    },
    "batches": [
      {
        "batch_id": "HPMC/0",
        "medium": "Deionized water",
        "release_mechanism": "Diffusion through gelled HPMC matrix",
