{
  "article_summary": {
    "title": "Effect of a Pharmaceutical Cationic Exchange Resin on the Properties of Controlled Release Diphenhydramine Hydrochloride Matrices Using Methocel K4M or Ethocel 7cP as Matrix Formers",
    "authors": ["Prasert Akkaramongkolporn", "Tanasait Ngawhirunpat", "Jurairat Nunthanid", "Praneet Opanasopit"],
    "journal": "AAPS PharmSciTech",
    "year": 2008,
    "doi": "10.1208/s12249-008-9129-6"
  },
  "materials_origin": {
    "Amberlite_IRP_69": "Sigma Chemical Co., USA",
    "Diphenhydramine_hydrochloride": "Beijing Shuanglao Pharmaceutical Co., China",
    "Potassium_chloride": "Ajax Finechem, Australia",
    "Methocel_K4M_HPMC": "Colorcon Ltd., UK",
    "Ethocel_7cP_EC": "Colorcon Ltd., UK",
    "Magnesium_stearate": "Glaxo Wellcome Vidhyasom, Thailand (BP grade)",
    "Deionized_water": "Prepared by Barnstead/Thermolyne D 4745 water purifier, USA"
  },
  "experimental_design": {
    "type": "Factorial evaluation of resin concentration and polymer type",
    "independent_variables": [
      {
        "name": "Resin (Amberlite IRP-69) concentration",
        "levels_percent_w_w": [0, 5, 10, 20, 30, 40]
      },
      {
        "name": "Polymer type",
        "levels": ["Methocel K4M (HPMC)", "Ethocel 7cP (EC)"]
      }
    ],
    "response_variables": [
      "Tablet diameter", "thickness", "hardness", "friability", "surface morphology",
      "drug release in deionized water and ionic solutions", "disintegration time"
    ]
  },
  "ingredients_identification": {
    "preparation_method": "Direct compression using hydraulic hand press. Blending for 10 min, then 100 mg portions compressed with 5 tons force for 5 s dwelling time.",
    "absorbance": "UV spectrophotometry at 218 nm",
    "equation": "Ion exchange reaction: RSO3Na + DPH+ ⇌ RSO3DPH + Na+; also competition with K+"
  },
